{% comment %}
  Avyen - Product Template: Scalp Cleanse
{% endcomment %}

<style>
    :root {
        --primary: #121212;
        --secondary: #c9a227;
        --background: #ffffff;
        --text: #121212;
        --border: #eeeeee;
        --font-serif: 'Playfair Display', serif;
        --font-sans: 'Inter', sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    .announcement-bar { background: #000; color: #fff; text-align: center; padding: 10px 0; font-size: 12px; text-transform: uppercase; letter-spacing: 2px; }
    @media (max-width: 768px) {
        .announcement-bar { font-size: 10px; padding: 12px 3%; white-space: normal; line-height: 1.35; }
    }

    header { display: flex; justify-content: space-between; align-items: center; padding: 20px 5%; border-bottom: 1px solid #eee; position: sticky; top: 0; background: #fff; z-index: 1000; }
    .logo { font-family: var(--font-serif); font-size: 32px; font-weight: 700; color: var(--primary); text-decoration: none; letter-spacing: 4px; position: absolute; left: 50%; transform: translateX(-50%); }
    nav { display: flex; flex-wrap: wrap; align-items: center; gap: 6px 10px; max-width: 44%; }
    nav a { text-decoration: none; color: #000; font-weight: 600; font-size: 11px; text-transform: uppercase; margin: 0; letter-spacing: 0.5px; white-space: nowrap; }
    .header-icons { display: flex; gap: 20px; }

    .menu-btn { display: none; cursor: pointer; }
    
    .mobile-drawer {
        position: fixed;
        top: 0;
        left: -100%;
        width: 80%;
        max-width: 350px;
        height: 100%;
        background: #fff;
        z-index: 2000;
        transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        box-shadow: 20px 0 60px rgba(0,0,0,0.1);
        overflow-y: auto;
    }
    .mobile-drawer.active { left: 0; }
    
    .drawer-header {
        background: var(--primary);
        padding: 60px 30px 40px;
        position: relative;
    }
    .drawer-logo {
        font-family: var(--font-serif);
        font-size: 32px;
        color: #fff;
        font-weight: 700;
        letter-spacing: 4px;
        margin-bottom: 10px;
    }
    .drawer-subtitle {
        color: rgba(255,255,255,0.6);
        font-size: 13px;
        letter-spacing: 1px;
    }
    .drawer-close {
        color: #fff;
        position: absolute;
        top: 20px;
        right: 20px;
        font-size: 28px;
        cursor: pointer;
    }
    .drawer-links {
        padding: 20px 0;
    }
    .drawer-link {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 18px 30px;
        text-decoration: none;
        color: var(--primary);
        font-weight: 700;
        font-size: 14px;
        letter-spacing: 1px;
        transition: 0.3s;
    }
    .drawer-link svg {
        width: 20px;
        height: 20px;
        opacity: 0.6;
    }
    .drawer-link.active {
        background: #f5f5f5;
        color: var(--primary);
    }
    .drawer-link:hover {
        background: #fafafa;
    }
    .drawer-sep {
        padding: 30px 30px 15px;
        font-size: 11px;
        font-weight: 700;
        color: #bbb;
        text-transform: uppercase;
        letter-spacing: 2px;
    }
    .drawer-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.4);
        backdrop-filter: blur(4px);
        z-index: 1999;
        opacity: 0;
        visibility: hidden;
        transition: 0.3s;
    }
    .drawer-overlay.active { opacity: 1; visibility: visible; }

    @media (max-width: 768px) {
        header { justify-content: flex-end; }
        nav { display: none; }
        .menu-btn { display: block; position: absolute; left: 5%; }
        .logo { font-size: 24px; letter-spacing: 2px; }
    }

    .product-main { display: flex; padding: 60px 5%; gap: 60px; max-width: 1400px; margin: 0 auto; align-items: flex-start; }
    .product-gallery { flex: 1.2; position: sticky; top: 120px; }
    .main-image { width: 100%; height: 650px; background-color: #f7f7f7; border-radius: 12px; overflow: hidden; display: flex; align-items: center; justify-content: center; }
    .main-image img { width: 100%; height: 100%; object-fit: cover; }

    .product-details { flex: 1; }
    .product-details h1 { font-family: var(--font-serif); font-size: 48px; color: var(--primary); line-height: 1.1; margin-bottom: 10px; }
    .subtitle { font-size: 14px; color: var(--secondary); margin-bottom: 12px; text-transform: none; letter-spacing: 0.08em; font-weight: 700; }
    .offer-badge {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--primary);
        background: rgba(201, 162, 39, 0.14);
        border: 1px solid rgba(201, 162, 39, 0.4);
        padding: 11px 16px;
        border-radius: 10px;
        margin-bottom: 22px;
        max-width: 520px;
        line-height: 1.45;
    }
    .description { font-size: 16px; color: #444; margin-bottom: 28px; max-width: 520px; line-height: 1.8; }
    .key-benefits { margin-bottom: 32px; text-align: left; max-width: 520px; }
    .key-benefits h3 {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 16px;
    }
    .key-benefits ul { list-style: none; padding: 0; margin: 0; }
    .key-benefits li {
        position: relative;
        padding-left: 22px;
        margin-bottom: 12px;
        font-size: 15px;
        color: #444;
        line-height: 1.55;
    }
    .key-benefits li:last-child { margin-bottom: 0; }
    .key-benefits li::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0.55em;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--secondary);
    }

    .result-section {
        padding: 72px 5% 80px;
        background: #faf8f5;
        border-top: 1px solid rgba(0,0,0,0.06);
        text-align: center;
    }
    .result-section__inner {
        max-width: 640px;
        margin: 0 auto;
    }
    .result-section h2 {
        font-family: var(--font-serif);
        font-size: clamp(28px, 4vw, 38px);
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 18px;
        line-height: 1.2;
    }
    .result-section p {
        font-size: 17px;
        line-height: 1.7;
        color: #555;
        margin: 0;
    }


    .bundle-selector { margin-bottom: 35px; display: flex; flex-direction: column; gap: 15px; }
    .bundle-card { border: 1px solid #ddd; border-radius: 12px; padding: 22px; cursor: pointer; transition: 0.3s; position: relative; display: flex; justify-content: space-between; align-items: center; }
    .bundle-card--solo { cursor: default; }
    .bundle-card:hover { border-color: var(--primary); }
    .bundle-card.selected { border-color: var(--primary); background: #fafafa; border-width: 2px; }
    .bundle-card.selected::after { content: '✓'; position: absolute; top: -10px; right: -10px; background: var(--primary); color: #fff; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; }
    
    .bundle-info h4 { font-size: 16px; margin-bottom: 4px; text-transform: uppercase; letter-spacing: 1px; }
    .bundle-info p { font-size: 13px; color: #777; }
    .bundle-price { font-weight: 700; font-size: 18px; }
    .bundle-price-stack { text-align: right; }
    .bundle-price-note {
        font-size: 12px;
        font-weight: 600;
        color: #666;
        margin-top: 6px;
        line-height: 1.35;
    }
    .bundle-price-note strong { color: var(--secondary); font-weight: 700; }
    .bundle-gift-tag {
        display: inline-block;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--primary);
        background: rgba(201, 162, 39, 0.2);
        padding: 5px 10px;
        border-radius: 6px;
        margin-right: 10px;
        vertical-align: middle;
    }

    .atc-btn { width: 100%; background: #000; color: #fff; padding: 22px; border: none; border-radius: 50px; font-weight: 700; font-size: 15px; text-transform: none; cursor: pointer; letter-spacing: 0.02em; transition: 0.3s; margin-bottom: 45px; }
    .atc-btn:hover { background: var(--secondary); color: #000; }

    .accordion { border-top: 1px solid var(--border); }
    .accordion-item { border-bottom: 1px solid var(--border); }
    .accordion-header { width: 100%; padding: 25px 0; background: none; border: none; display: flex; justify-content: space-between; align-items: center; font-weight: 700; font-size: 12px; text-transform: uppercase; cursor: pointer; letter-spacing: 2px; color: #000; -webkit-appearance: none; }
    .accordion-content { padding-bottom: 25px; font-size: 14px; color: #666; display: none; line-height: 1.7; }
    .accordion-item.active .accordion-content { display: block; }

    .feature-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 60px; padding: 120px 5%; background: #fff; max-width: 1400px; margin: 0 auto; align-items: center; }
    .feature-item h2 { font-family: var(--font-serif); font-size: 38px; margin-bottom: 25px; line-height: 1.2; }
    .feature-item p { font-size: 16px; color: #555; line-height: 1.8; }
    .feature-image { width: 100%; aspect-ratio: 1; background: #f9f9f9; border-radius: 20px; overflow: hidden; }
    .feature-image img { width: 100%; height: 100%; object-fit: cover; }

    @media (max-width: 768px) {
        .product-main { flex-direction: column; padding: 30px 5%; align-items: stretch; }
        .product-gallery { position: relative; top: 0; }
        .main-image { height: 450px; }
        .feature-grid { grid-template-columns: 1fr; padding: 80px 5%; }
        .product-details h1 { font-size: 36px; }
        .header-icon-account { display: none; }
    }

    .community-section {
        padding: 100px 5%;
        background: #fff;
        text-align: left;
        max-width: 1400px;
        margin: 0 auto;
    }
    .community-section h2 {
        font-family: var(--font-sans);
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 40px;
        color: var(--primary);
    }
    .community-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
    }
    .community-item {
        aspect-ratio: 1;
        background: #f7f7f7;
        border-radius: 12px;
        overflow: hidden;
    }
    @media (max-width: 768px) {
        .community-grid { 
            display: flex; 
            overflow-x: auto; 
            gap: 15px; 
            padding-bottom: 20px; 
            margin: 0 -5%; 
            padding: 0 5%;
            scroll-snap-type: x mandatory; 
            scrollbar-width: none;
        }
        .community-grid::-webkit-scrollbar { display: none; }
        .community-item { flex: 0 0 75%; scroll-snap-align: start; }
    }

    .faq-section {
        padding: 100px 5%;
        display: flex;
        gap: 80px;
        max-width: 1400px;
        margin: 0 auto;
        align-items: center;
        background: #fff;
    }
    .faq-container { flex: 1; text-align: left; }
    .faq-container h2 { font-family: var(--font-sans); font-size: 32px; font-weight: 700; margin-bottom: 40px; }
    .faq-image { flex: 1; border-radius: 20px; overflow: hidden; height: 550px; background: #f9f9f9; }
    
    .faq-item { border-bottom: 1px solid var(--border); }
    .faq-question {
        width: 100%;
        padding: 25px 0;
        background: none;
        border: none;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 600;
        font-size: 16px;
        cursor: pointer;
        text-align: left;
        color: var(--primary);
    }
    .faq-answer { padding-bottom: 25px; font-size: 15px; color: #666; display: none; line-height: 1.6; }
    .faq-item.active .faq-answer { display: block; }
    .faq-item.active .faq-question span { transform: rotate(45deg); }
    .faq-question span { transition: transform 0.3s; font-size: 24px; color: #999; }

    @media (max-width: 768px) {
        .faq-section { flex-direction: column; gap: 40px; padding: 60px 5%; }
        .faq-image { width: 100%; height: 350px; }
    }

    .reviews-section {
        padding: 100px 5%;
        background: #fff;
        max-width: 1400px;
        margin: 0 auto;
        border-top: 1px solid var(--border);
    }
    .review-item {
        padding: 40px 0;
        border-bottom: 1px solid #f0f0f0;
        display: flex;
        gap: 60px;
    }
    .review-meta { flex: 0 0 150px; }
    .review-author { font-weight: 700; font-size: 16px; margin-bottom: 5px; }
    .review-status { font-size: 12px; color: #999; text-transform: uppercase; letter-spacing: 1px; }
    .review-content { flex: 1; }
    .stars { color: #000; font-size: 14px; margin-bottom: 15px; letter-spacing: 2px; }
    .review-title { font-weight: 700; font-size: 18px; margin-bottom: 10px; }
    .review-text { font-style: italic; color: #444; line-height: 1.8; font-size: 16px; }

    @media (max-width: 768px) {
        .review-item { flex-direction: column; gap: 20px; }
        .review-meta { flex: none; }
    }

    footer {
        background: var(--primary);
        color: #fff;
        padding: 80px 5% 40px;
    }
    .footer-content {
        display: grid;
        grid-template-columns: 1.5fr 0.8fr 0.8fr 1.5fr;
        gap: 60px;
        max-width: 1400px;
        margin: 0 auto 60px;
    }
    .footer-col h3 {
        font-family: var(--font-sans);
        font-size: 14px;
        font-weight: 700;
        margin-bottom: 25px;
        color: #fff;
        text-transform: uppercase;
        letter-spacing: 2px;
    }
    .footer-brand .footer-logo {
        color: #fff;
        display: block;
        margin-bottom: 20px;
        font-size: 28px;
        font-family: var(--font-serif);
        text-decoration: none;
        letter-spacing: 4px;
        font-weight: 700;
    }
    .footer-brand p {
        font-size: 14px;
        line-height: 1.6;
        color: rgba(255,255,255,0.7);
        margin-bottom: 20px;
    }
    .footer-usp {
        list-style: none;
        font-size: 13px;
        color: rgba(255,255,255,0.6);
        margin-bottom: 20px;
    }
    .footer-usp li { margin-bottom: 8px; display: flex; align-items: center; gap: 10px; }
    .footer-usp li::before { content: '•'; color: var(--secondary); }
    
    .footer-social { display: flex; gap: 20px; margin-top: 20px; }
    .footer-social a { color: #fff; opacity: 0.7; transition: 0.3s; }
    .footer-social a:hover { opacity: 1; color: var(--secondary); }

    .footer-links-list { display: flex; flex-direction: column; gap: 12px; }
    .footer-links-list a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 14px; transition: 0.3s; }
    .footer-links-list a:hover { color: var(--secondary); }

    .footer-newsletter p { font-size: 14px; color: rgba(255,255,255,0.7); margin-bottom: 20px; line-height: 1.5; }
    .newsletter-form { display: flex; gap: 10px; }
    .newsletter-input {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 14px 20px;
        border-radius: 40px;
        color: #fff;
        flex: 1;
        outline: none;
        font-size: 14px;
    }
    .newsletter-input::placeholder { color: rgba(255,255,255,0.3); }
    .newsletter-btn {
        background: #fff;
        color: var(--primary);
        border: none;
        padding: 14px 30px;
        border-radius: 40px;
        font-weight: 700;
        cursor: pointer;
        transition: 0.3s;
        text-transform: uppercase;
        font-size: 13px;
        letter-spacing: 1px;
    }
    .newsletter-btn:hover { background: var(--secondary); color: #fff; }

    .footer-bottom {
        border-top: 1px solid rgba(255,255,255,0.1);
        padding-top: 30px;
        text-align: center;
        font-size: 12px;
        color: rgba(255,255,255,0.4);
        letter-spacing: 1px;
    }

    @media (max-width: 1024px) {
        .footer-content { grid-template-columns: repeat(2, 1fr); gap: 40px; }
    }
    @media (max-width: 600px) {
        .footer-content { grid-template-columns: 1fr; text-align: center; }
        .footer-usp li, .footer-social, .newsletter-form { justify-content: center; }
        .footer-links-list { align-items: center; }
    }
</style>

