{% comment %} Order confirmation — animated flow step 4 {% endcomment %}
<style>
    :root { --primary: #121212; --secondary: #c9a227; --font-serif: 'Playfair Display', serif; --font-sans: 'Inter', sans-serif; }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--font-sans); color: var(--primary); background: #fff; }
    .announcement-bar { background: #000; color: #fff; text-align: center; padding: 10px 0; font-size: 12px; text-transform: uppercase; letter-spacing: 2px; }
    header { display: flex; justify-content: space-between; align-items: center; padding: 20px 5%; border-bottom: 1px solid #eee; background: #fff; }
    nav a { text-decoration: none; color: #000; font-weight: 600; font-size: 11px; text-transform: uppercase; margin-right: 10px; }
    .order-success-main { padding: 60px 5% 80px; max-width: 640px; margin: 0 auto; text-align: center; }
    .order-success-main h1 { font-family: var(--font-serif); font-size: clamp(32px, 6vw, 44px); margin-bottom: 12px; }
    .order-success-main p { font-size: 16px; color: #555; line-height: 1.7; margin-bottom: 32px; }
    .order-success-main .order-flow { margin-left: auto; margin-right: auto; }
    .order-success-actions { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; margin-top: 28px; }
    .order-success-actions a {
        display: inline-block; padding: 14px 28px; border-radius: 50px; font-weight: 700; font-size: 13px;
        text-decoration: none; letter-spacing: 0.04em;
    }
    .btn-primary { background: #000; color: #fff; }
    .btn-secondary { border: 1px solid #ddd; color: #121212; }
</style>

{% assign wa_digits = '923257228456' %}

<div class="announcement-bar">Limited-Time BOGO Offer — Buy Scalp Cleanse &amp; Get Conditioning Creme FREE</div>

<header>
    <nav><a href="/">Home</a><a href="/collections/all">Shop</a></nav>
    {% render 'site-logo' %}
    <a href="javascript:void(0)" onclick="gOpenCart()" style="color:#000;">Cart</a>
</header>

<main class="order-success-main">
    <h1>Thank You!</h1>
    <p>Your Avyen order has been placed. We will confirm and dispatch it soon. You may receive a call or WhatsApp from our team.</p>
    {% render 'order-flow-animated', flow_step: 4 %}
    <div class="order-success-actions">
        <a href="/collections/all" class="btn-primary">Continue Shopping</a>
        <a href="{% if wa_digits != blank %}https://wa.me/{{ wa_digits }}{% else %}/pages/contact{% endif %}" class="btn-secondary" {% if wa_digits != blank %}target="_blank" rel="noopener noreferrer"{% endif %}>WhatsApp Support</a>
    </div>
</main>
