{% comment %}
  Shipping & Delivery Policy — theme template
  In Shopify Admin: Online Store > Pages > create/edit page > Theme template: shipping-policy
  URL handle: use shipping-delivery-policy (from title) or edit SEO to shipping-policy — links in theme use shipping-delivery-policy
  Page title (admin): Shipping & Delivery Policy
  Page body can stay empty; copy lives in this template.
{% endcomment %}

<style>
    :root {
        --primary: #121212;
        --secondary: #c9a227;
        --font-serif: 'Playfair Display', serif;
        --font-sans: 'Inter', sans-serif;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--font-sans); color: var(--primary); background: #fff; overflow-x: hidden; }

    .announcement-bar { background: #000; color: #fff; text-align: center; padding: 10px 0; font-size: 12px; text-transform: uppercase; letter-spacing: 2px; }
    @media (max-width: 768px) {
        .announcement-bar { font-size: 10px; padding: 12px 3%; white-space: normal; line-height: 1.35; }
    }

    header { display: flex; justify-content: space-between; align-items: center; padding: 20px 5%; border-bottom: 1px solid #eee; position: sticky; top: 0; background: #fff; z-index: 1000; }
    .logo { font-family: var(--font-serif); font-size: 32px; font-weight: 700; color: var(--primary); text-decoration: none; letter-spacing: 4px; position: absolute; left: 50%; transform: translateX(-50%); }
    nav { display: flex; flex-wrap: wrap; align-items: center; gap: 6px 10px; max-width: 44%; }
    nav a { text-decoration: none; color: #000; font-weight: 600; font-size: 11px; text-transform: uppercase; margin: 0; letter-spacing: 0.5px; white-space: nowrap; }
    .header-icons { display: flex; gap: 20px; }
    .menu-btn { display: none; cursor: pointer; }
    @media (max-width: 768px) {
        header { justify-content: flex-end; }
        nav { display: none; }
        .menu-btn { display: block; position: absolute; left: 5%; }
        .logo { font-size: 24px; letter-spacing: 2px; }
        .header-icon-account { display: none; }
    }

    .mobile-drawer {
        position: fixed; top: 0; left: -100%; width: 80%; max-width: 350px; height: 100%;
        background: #fff; z-index: 2000; transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex; flex-direction: column; box-shadow: 20px 0 60px rgba(0,0,0,0.1);
    }
    .mobile-drawer.active { left: 0; }
    .drawer-header { background: var(--primary); padding: 60px 30px 40px; position: relative; }
    .drawer-logo { font-family: var(--font-serif); font-size: 32px; color: #fff; font-weight: 700; letter-spacing: 4px; margin-bottom: 10px; }
    .drawer-subtitle { color: rgba(255,255,255,0.6); font-size: 13px; letter-spacing: 1px; }
    .drawer-close { color: #fff; position: absolute; top: 20px; right: 20px; font-size: 28px; cursor: pointer; }
    .drawer-links { padding: 20px 0; }
    .drawer-link { display: flex; align-items: center; gap: 20px; padding: 18px 30px; text-decoration: none; color: var(--primary); font-weight: 700; font-size: 14px; letter-spacing: 1px; }
    .drawer-link svg { width: 20px; height: 20px; opacity: 0.6; }
    .drawer-sep { padding: 30px 30px 15px; font-size: 11px; font-weight: 700; color: #bbb; text-transform: uppercase; letter-spacing: 2px; }
    .drawer-overlay {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.4); backdrop-filter: blur(4px); z-index: 1999;
        opacity: 0; visibility: hidden; transition: 0.3s;
    }
    .drawer-overlay.active { opacity: 1; visibility: visible; }

    .policy-wrap { max-width: 720px; margin: 0 auto; padding: 72px 5% 100px; }
    .policy-wrap h1 {
        font-family: var(--font-serif);
        font-size: clamp(32px, 5vw, 46px);
        font-weight: 700;
        margin-bottom: 16px;
        line-height: 1.15;
    }
    .policy-lead {
        font-size: 17px;
        color: #555;
        line-height: 1.65;
        margin-bottom: 40px;
        padding-bottom: 32px;
        border-bottom: 1px solid #eee;
    }
    .policy-section { margin-bottom: 32px; }
    .policy-section h2 {
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-weight: 700;
        color: var(--secondary);
        margin-bottom: 10px;
    }
    .policy-section p {
        font-size: 16px;
        line-height: 1.7;
        color: #444;
    }
    .policy-section a { color: var(--primary); font-weight: 600; }

    footer { background: var(--primary); color: #fff; padding: 80px 5% 40px; }
    .footer-content { display: grid; grid-template-columns: 1.5fr 0.8fr 0.8fr 1.5fr; gap: 60px; max-width: 1400px; margin: 0 auto 60px; }
    .footer-col h3 { font-size: 14px; font-weight: 700; margin-bottom: 25px; text-transform: uppercase; letter-spacing: 2px; }
    .footer-brand .footer-logo { color: #fff; display: block; margin-bottom: 20px; font-size: 28px; font-family: var(--font-serif); text-decoration: none; letter-spacing: 4px; font-weight: 700; }
    .footer-brand p { font-size: 14px; line-height: 1.6; color: rgba(255,255,255,0.7); margin-bottom: 20px; }
    .footer-links-list { display: flex; flex-direction: column; gap: 12px; }
    .footer-links-list a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 14px; transition: 0.3s; }
    .footer-links-list a:hover { color: var(--secondary); }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 30px; text-align: center; font-size: 12px; color: rgba(255,255,255,0.4); }
    @media (max-width: 900px) {
        .footer-content { grid-template-columns: 1fr 1fr; gap: 40px; }
    }
    @media (max-width: 600px) {
        .footer-content { grid-template-columns: 1fr; text-align: center; }
        .footer-links-list { align-items: center; }
    }
</style>

