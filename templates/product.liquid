{% comment %}
  Avyen - Product Template (Revitalizing Shampoo)
{% endcomment %}

<style>
    :root {
        --primary: #121212;
        --secondary: #c9a227;
        --background: #ffffff;
        --text: #121212;
        --border: #eeeeee;
        --font-serif: 'Playfair Display', serif;
        --font-sans: 'Inter', sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--font-sans); color: var(--text); background: var(--background); line-height: 1.6; }

    header { display: flex; justify-content: space-between; align-items: center; padding: 20px 5%; border-bottom: 1px solid #eee; background: #fff; position: sticky; top: 0; z-index: 100; }
    .logo { font-family: var(--font-serif); font-size: 28px; color: var(--primary); text-decoration: none; position: absolute; left: 50%; transform: translateX(-50%); font-weight: 700; letter-spacing: 2px; }
    nav { display: flex; flex-wrap: wrap; align-items: center; gap: 6px 12px; max-width: 50%; }
    nav a { text-decoration: none; color: #000; font-weight: 600; font-size: 11px; text-transform: uppercase; margin: 0; letter-spacing: 0.5px; white-space: nowrap; }
    .announcement-bar { background: #000; color: #fff; text-align: center; padding: 10px 0; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; }

    .product-main { display: flex; padding: 60px 5%; gap: 60px; max-width: 1400px; margin: 0 auto; }
    .product-gallery { flex: 1.2; }
    .main-image { width: 100%; height: 600px; background-color: #f5f5f5; border-radius: 12px; overflow: hidden; display: flex; align-items: center; justify-content: center; color: #999; }
    .main-image img { width: 100%; height: 100%; object-fit: cover; }

    .product-details { flex: 1; }
    .product-details h1 { font-family: var(--font-serif); font-size: 42px; color: var(--primary); line-height: 1.2; margin-bottom: 10px; }
    .subtitle { font-size: 18px; color: #666; margin-bottom: 20px; text-transform: uppercase; letter-spacing: 1px; }
    .description { font-size: 16px; color: #444; margin-bottom: 30px; max-width: 500px; }
    .price { font-size: 28px; font-weight: 700; color: var(--primary); margin-bottom: 30px; }

    .bundle-selector { margin-bottom: 30px; display: flex; flex-direction: column; gap: 15px; }
    .bundle-card { border: 2px solid #eee; border-radius: 12px; padding: 20px; cursor: pointer; transition: 0.3s; position: relative; display: flex; justify-content: space-between; align-items: center; }
    .bundle-card:hover { border-color: var(--primary); }
    .bundle-card.selected { border-color: var(--primary); background: #fafafa; }
    .bundle-card.selected::after { content: '✓'; position: absolute; top: -10px; right: -10px; background: var(--primary); color: #fff; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 14px; }
    
    .bundle-info h4 { font-size: 16px; margin-bottom: 4px; }
    .bundle-info p { font-size: 13px; color: #666; }
    .bundle-price { font-weight: 700; font-size: 16px; }

    .atc-btn { width: 100%; background: #000; color: #fff; padding: 20px; border: none; border-radius: 40px; font-weight: 700; font-size: 16px; text-transform: uppercase; cursor: pointer; letter-spacing: 2px; transition: 0.3s; margin-bottom: 40px; }
    .atc-btn:hover { background: #333; }

    .accordion { border-top: 1px solid var(--border); }
    .accordion-item { border-bottom: 1px solid var(--border); }
    .accordion-header { width: 100%; padding: 20px 0; background: none; border: none; display: flex; justify-content: space-between; align-items: center; font-weight: 700; font-size: 13px; text-transform: uppercase; cursor: pointer; letter-spacing: 1px; }
    .accordion-content { padding-bottom: 20px; font-size: 14px; color: #555; display: none; }
    .accordion-item.active .accordion-content { display: block; }

    .feature-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 40px; padding: 100px 5%; background: #f9f9f9; }
    .feature-item h2 { font-family: var(--font-serif); font-size: 32px; margin-bottom: 20px; }
    .feature-item p { font-size: 16px; color: #555; }

    @media (max-width: 768px) {
        .product-main { flex-direction: column; padding: 20px 5%; }
        .main-image { height: 350px; }
        .feature-grid { grid-template-columns: 1fr; }
    }
</style>

