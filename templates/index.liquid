{% comment %}
  Avyen - Homepage Template
{% endcomment %}

<style>
    :root {
        --primary: #121212;
        --secondary: #c9a227; /* Gold accent for premium feel */
        --background: #ffffff;
        --text: #121212;
        --font-serif: 'Playfair Display', serif;
        --font-sans: 'Inter', sans-serif;
        --accent-bg: #f9f9f9;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--font-sans); color: var(--text); background: var(--background); overflow-x: hidden; }

    .announcement-bar { background: #000; color: #fff; text-align: center; padding: 10px 0; font-size: 12px; text-transform: uppercase; letter-spacing: 2px; }
    @media (max-width: 768px) {
        .announcement-bar { font-size: 10px; padding: 12px 3%; white-space: normal; line-height: 1.35; }
    }

    header { display: flex; justify-content: space-between; align-items: center; padding: 20px 5%; border-bottom: 1px solid #eee; position: sticky; top: 0; background: #fff; z-index: 1000; }
    .logo { font-family: var(--font-serif); font-size: 32px; font-weight: 700; color: var(--primary); text-decoration: none; letter-spacing: 4px; position: absolute; left: 50%; transform: translateX(-50%); }
    nav { display: flex; flex-wrap: wrap; align-items: center; gap: 6px 10px; max-width: 44%; }
    nav a { text-decoration: none; color: #000; font-weight: 600; font-size: 11px; text-transform: uppercase; margin: 0; letter-spacing: 0.5px; white-space: nowrap; }
    .header-icons { display: flex; gap: 20px; }

    .menu-btn { display: none; cursor: pointer; }
    
    .mobile-drawer {
        position: fixed;
        top: 0;
        left: -100%;
        width: 80%;
        max-width: 350px;
        height: 100%;
        background: #fff;
        z-index: 2000;
        transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        box-shadow: 20px 0 60px rgba(0,0,0,0.1);
        overflow-y: auto;
    }
    .mobile-drawer.active { left: 0; }
    
    .drawer-header {
        background: var(--primary);
        padding: 60px 30px 40px;
        position: relative;
    }
    .drawer-logo {
        font-family: var(--font-serif);
        font-size: 32px;
        color: #fff;
        font-weight: 700;
        letter-spacing: 4px;
        margin-bottom: 10px;
    }
    .drawer-subtitle {
        color: rgba(255,255,255,0.6);
        font-size: 13px;
        letter-spacing: 1px;
    }
    .drawer-close {
        color: #fff;
        position: absolute;
        top: 20px;
        right: 20px;
        font-size: 28px;
        cursor: pointer;
    }
    .drawer-links {
        padding: 20px 0;
    }
    .drawer-link {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 18px 30px;
        text-decoration: none;
        color: var(--primary);
        font-weight: 700;
        font-size: 14px;
        letter-spacing: 1px;
        transition: 0.3s;
    }
    .drawer-link svg {
        width: 20px;
        height: 20px;
        opacity: 0.6;
    }
    .drawer-link.active {
        background: #f5f5f5;
        color: var(--primary);
    }
    .drawer-link:hover {
        background: #fafafa;
    }
    .drawer-sep {
        padding: 30px 30px 15px;
        font-size: 11px;
        font-weight: 700;
        color: #bbb;
        text-transform: uppercase;
        letter-spacing: 2px;
    }
    .drawer-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.4);
        backdrop-filter: blur(4px);
        z-index: 1999;
        opacity: 0;
        visibility: hidden;
        transition: 0.3s;
    }
    .drawer-overlay.active { opacity: 1; visibility: visible; }

    @media (max-width: 768px) {
        header { justify-content: flex-end; }
        nav { display: none; }
        .menu-btn { display: block; position: absolute; left: 5%; }
        .logo { font-size: 24px; letter-spacing: 2px; }
    }

    .hero { 
        width: 100%; 
        height: 80vh; 
        background-color: #f0f0f0; 
        background-image: url("{{ 'web-banner.jpg' | asset_url }}");
        background-size: cover;
        background-position: center;
        display: flex; 
        align-items: center; 
        justify-content: center; 
        position: relative; 
        overflow: hidden; 
    }
    .hero-content { position: relative; z-index: 2; text-align: center; color: #000; }
    .hero-content h1 { font-family: var(--font-serif); font-size: clamp(40px, 8vw, 80px); margin-bottom: 20px; line-height: 1.1; }
    .hero-content p { font-size: 18px; margin-bottom: 30px; letter-spacing: 1px; }
    .cta-button { display: inline-block; background: #000; color: #fff; padding: 18px 45px; text-decoration: none; border-radius: 40px; font-weight: 700; text-transform: uppercase; font-size: 14px; letter-spacing: 2px; transition: 0.3s; position: relative; z-index: 3; }
    .cta-button:hover { background: var(--secondary); color: #000; }

    .trust-badges {
        background: #f7f4ef;
        border-top: 1px solid rgba(61, 43, 43, 0.08);
        border-bottom: 1px solid rgba(61, 43, 43, 0.08);
    }
    .trust-badges-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 36px 5%;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 28px;
        align-items: stretch;
    }
    .trust-badge {
        font-family: var(--font-sans);
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: #3d2b2b;
        line-height: 1.45;
        padding: 18px 16px;
        background: rgba(255,255,255,0.65);
        border: 1px solid rgba(61, 43, 43, 0.1);
        border-radius: 12px;
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 72px;
    }
    @media (max-width: 900px) {
        .trust-badges-inner {
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
            padding: 28px 5%;
        }
    }
    @media (max-width: 768px) {
        .trust-badges-inner {
            display: flex;
            flex-wrap: nowrap;
            overflow-x: auto;
            scroll-snap-type: x mandatory;
            gap: 14px;
            padding: 24px 5% 28px;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
            overscroll-behavior-x: contain;
        }
        .trust-badges-inner::-webkit-scrollbar { display: none; }
        .trust-badge {
            flex: 0 0 min(88vw, 340px);
            scroll-snap-align: center;
            scroll-snap-stop: always;
            min-height: 88px;
            padding: 20px 18px;
            font-size: 11px;
        }
    }

    .section-container { padding: 100px 5%; text-align: center; }
    .hollow-heading {
        font-family: "Segoe Script", "Brush Script MT", cursive !important;
        font-size: clamp(30px, 6vw, 60px);
        color: #000;
        -webkit-text-stroke: 0;
        text-transform: none;
        margin-bottom: 50px;
    }

    .products-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 40px; max-width: 1200px; margin: 0 auto; }
    .product-item { text-decoration: none; color: #000; transition: 0.3s; }
    .product-item-img { width: 100%; aspect-ratio: 1; background: #f5f5f5; border-radius: 12px; margin-bottom: 20px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .product-item-img img { width: 100%; height: 100%; object-fit: cover; }
    .product-item h3 { font-family: var(--font-serif); font-size: 22px; margin-bottom: 5px; }
    .product-item p { color: #666; font-size: 16px; margin-bottom: 10px; }
    .product-item .price { font-weight: 700; font-size: 18px; color: var(--secondary); margin-bottom: 15px; }
    .product-btn { 
        display: inline-block; 
        background: #000; 
        color: #fff; 
        padding: 12px 35px; 
        border-radius: 50px; 
        font-size: 12px; 
        font-weight: 700; 
        text-transform: uppercase; 
        letter-spacing: 1px; 
        transition: 0.3s; 
    }
    .product-item:hover .product-btn { background: var(--secondary); color: #000; }

    .bogo-strip {
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--primary);
        margin: -30px auto 40px;
        max-width: 1200px;
    }

    footer {
        background: var(--primary);
        color: #fff;
        padding: 80px 5% 40px;
    }
    .footer-content {
        display: grid;
        grid-template-columns: 1.5fr 0.8fr 0.8fr 1.5fr;
        gap: 60px;
        max-width: 1400px;
        margin: 0 auto 60px;
    }
    .footer-col h3 {
        font-family: var(--font-sans);
        font-size: 14px;
        font-weight: 700;
        margin-bottom: 25px;
        color: #fff;
        text-transform: uppercase;
        letter-spacing: 2px;
    }
    .footer-brand .logo {
        position: static;
        transform: none;
        color: #fff;
        display: block;
        margin-bottom: 20px;
        font-size: 28px;
    }
    .footer-brand p {
        font-size: 14px;
        line-height: 1.6;
        color: rgba(255,255,255,0.7);
        margin-bottom: 20px;
    }
    .footer-usp {
        list-style: none;
        font-size: 13px;
        color: rgba(255,255,255,0.6);
        margin-bottom: 20px;
    }
    .footer-usp li { margin-bottom: 8px; display: flex; align-items: center; gap: 10px; }
    .footer-usp li::before { content: '•'; color: var(--secondary); }
    
    .footer-social { display: flex; gap: 20px; margin-top: 20px; }
    .footer-social a { color: #fff; opacity: 0.7; transition: 0.3s; }
    .footer-social a:hover { opacity: 1; color: var(--secondary); }

    .footer-links-list { display: flex; flex-direction: column; gap: 12px; }
    .footer-links-list a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 14px; transition: 0.3s; }
    .footer-links-list a:hover { color: var(--secondary); }

    .footer-newsletter p { font-size: 14px; color: rgba(255,255,255,0.7); margin-bottom: 20px; line-height: 1.5; }
    .newsletter-form { display: flex; gap: 10px; }
    .newsletter-input {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 14px 20px;
        border-radius: 40px;
        color: #fff;
        flex: 1;
        outline: none;
        font-size: 14px;
    }
    .newsletter-input::placeholder { color: rgba(255,255,255,0.3); }
    .newsletter-btn {
        background: #fff;
        color: var(--primary);
        border: none;
        padding: 14px 30px;
        border-radius: 40px;
        font-weight: 700;
        cursor: pointer;
        transition: 0.3s;
        text-transform: uppercase;
        font-size: 13px;
        letter-spacing: 1px;
    }
    .newsletter-btn:hover { background: var(--secondary); color: #fff; }

    .footer-bottom {
        border-top: 1px solid rgba(255,255,255,0.1);
        padding-top: 30px;
        text-align: center;
        font-size: 12px;
        color: rgba(255,255,255,0.4);
        letter-spacing: 1px;
    }

    @media (max-width: 1024px) {
        .footer-content { grid-template-columns: repeat(2, 1fr); gap: 40px; }
    }
    @media (max-width: 600px) {
        .footer-content { grid-template-columns: 1fr; text-align: center; }
        .footer-usp li, .footer-social, .newsletter-form { justify-content: center; }
        .footer-links-list { align-items: center; }
    }

    @media (max-width: 768px) {
        header nav { display: none; }
        .hero {
            background-image: url("{{ 'mobile-banner.jpg' | asset_url }}");
            height: 60vh;
        }
        .header-icon-account { display: none; }
    }

    .benefits-section {
        padding: 80px 5%;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 60px;
        max-width: 1300px;
        margin: 0 auto;
        text-align: center;
    }
    .benefit-item h3 {
        font-family: var(--font-serif);
        font-size: 28px;
        margin-bottom: 20px;
        line-height: 1.2;
        color: var(--primary);
    }
    .benefit-item p {
        color: #555;
        font-size: 15px;
        line-height: 1.7;
        max-width: 300px;
        margin: 0 auto;
    }
    @media (max-width: 768px) {
        .benefits-section {
            grid-template-columns: 1fr;
            gap: 50px;
            padding: 60px 5%;
        }
    }

    .concern-section {
        padding: 100px 5%;
        text-align: center;
        background: #fff;
    }
    .concern-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        max-width: 1400px;
        margin: 0 auto;
    }
    .concern-item {
        position: relative;
        aspect-ratio: 4/5;
        background: #f7f7f7;
        background-size: cover;
        background-position: center;
        border-radius: 15px;
        overflow: hidden;
        transition: transform 0.3s ease;
    }
    .concern-item:hover { transform: translateY(-5px); }
    @media (max-width: 1024px) {
        .concern-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
        .concern-grid {
            display: flex;
            overflow-x: auto;
            gap: 15px;
            padding: 0 5% 20px;
            scroll-snap-type: x mandatory;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
        }
        .concern-grid::-webkit-scrollbar { display: none; }
        .concern-item {
            flex: 0 0 280px;
            scroll-snap-align: start;
        }
        .concern-section { padding: 60px 0; }
        .concern-section .hollow-heading { padding: 0 5%; }
    }
</style>

