    <script>
        function toggleMenu() {
            document.getElementById('mobileDrawer').classList.toggle('active');
            document.querySelector('.drawer-overlay').classList.toggle('active');
        }
        function closeMenu() {
            document.getElementById('mobileDrawer').classList.remove('active');
            document.querySelector('.drawer-overlay').classList.remove('active');
        }
        (function initHomeStickyAtc() {
            const wrap = document.getElementById('homeStickyAtc');
            const shop = document.getElementById('shop');
            if (!wrap || !shop) return;
            const mq = window.matchMedia('(max-width: 768px)');
            let io = null;
            function setHidden(hidden) {
                wrap.classList.toggle('is-hidden', hidden);
            }
            function start() {
                if (io) io.disconnect();
                if (!mq.matches) {
                    setHidden(false);
                    return;
                }
                io = new IntersectionObserver(function(entries) {
                    entries.forEach(function(entry) {
                        setHidden(entry.isIntersecting && entry.intersectionRatio > 0.08);
                    });
                }, { threshold: [0, 0.08, 0.2, 0.4, 0.6] });
                io.observe(shop);
            }
            start();
            mq.addEventListener('change', start);
        })();
    </script>
