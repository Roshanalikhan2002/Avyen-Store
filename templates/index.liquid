{% comment %}
  Avyen - Homepage Template
{% endcomment %}

<style>
    :root {
        --primary: #121212;
        --secondary: #c9a227; /* Gold accent for premium feel */
        --background: #ffffff;
        --text: #121212;
        --font-serif: 'Playfair Display', serif;
        --font-sans: 'Inter', sans-serif;
        --accent-bg: #f9f9f9;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-sans); color: var(--text); background: var(--background); overflow-x: hidden; }
    section[id],
    footer[id] {
        scroll-margin-top: 88px;
    }


    header { display: flex; justify-content: space-between; align-items: center; padding: 20px 5%; border-bottom: 1px solid #eee; position: sticky; top: 0; background: #fff; z-index: 1000; }
    .logo { font-family: var(--font-serif); font-size: 32px; font-weight: 700; color: var(--primary); text-decoration: none; letter-spacing: 4px; position: absolute; left: 50%; transform: translateX(-50%); }
    nav { display: flex; flex-wrap: wrap; align-items: center; gap: 6px 10px; max-width: 44%; }
    nav a { text-decoration: none; color: #000; font-weight: 600; font-size: 11px; text-transform: uppercase; margin: 0; letter-spacing: 0.5px; white-space: nowrap; }
    .header-icons { display: flex; gap: 20px; }

    .menu-btn { display: none; cursor: pointer; }
    
    .mobile-drawer {
        position: fixed;
        top: 0;
        left: -100%;
        width: 80%;
        max-width: 350px;
        height: 100%;
        background: #fff;
        z-index: 2000;
        transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        box-shadow: 20px 0 60px rgba(0,0,0,0.1);
        overflow-y: auto;
    }
    .mobile-drawer.active { left: 0; }
    
    .drawer-header {
        background: var(--primary);
        padding: 60px 30px 40px;
        position: relative;
    }
    .drawer-logo {
        font-family: var(--font-serif);
        font-size: 32px;
        color: #fff;
        font-weight: 700;
        letter-spacing: 4px;
        margin-bottom: 10px;
    }
    .drawer-subtitle {
        color: rgba(255,255,255,0.6);
        font-size: 13px;
        letter-spacing: 1px;
    }
    .drawer-close {
        color: #fff;
        position: absolute;
        top: 20px;
        right: 20px;
        font-size: 28px;
        cursor: pointer;
    }
    .drawer-links {
        padding: 20px 0;
    }
    .drawer-link {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 18px 30px;
        text-decoration: none;
        color: var(--primary);
        font-weight: 700;
        font-size: 14px;
        letter-spacing: 1px;
        transition: 0.3s;
    }
    .drawer-link svg {
        width: 20px;
        height: 20px;
        opacity: 0.6;
    }
    .drawer-link.active {
        background: #f5f5f5;
        color: var(--primary);
    }
    .drawer-link:hover {
        background: #fafafa;
    }
    .drawer-sep {
        padding: 30px 30px 15px;
        font-size: 11px;
        font-weight: 700;
        color: #bbb;
        text-transform: uppercase;
        letter-spacing: 2px;
    }
    .drawer-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.4);
        backdrop-filter: blur(4px);
        z-index: 1999;
        opacity: 0;
        visibility: hidden;
        transition: 0.3s;
    }
    .drawer-overlay.active { opacity: 1; visibility: visible; }

    @media (max-width: 768px) {
        header { justify-content: flex-end; }
        nav { display: none; }
        .menu-btn { display: block; position: absolute; left: 5%; }
        .logo { font-size: 24px; letter-spacing: 2px; }
    }

    .hero { 
        width: 100%; 
        height: 80vh; 
        background-color: #f0f0f0; 
        background-image: url("{{ 'web-banner.jpg' | asset_url }}");
        background-size: cover;
        background-position: center;
        display: flex; 
        align-items: center; 
        justify-content: center; 
        position: relative; 
        overflow: hidden; 
    }
    .hero-content { position: relative; z-index: 2; text-align: center; color: #000; }
    .hero-content h1 { font-family: var(--font-serif); font-size: clamp(40px, 8vw, 80px); margin-bottom: 20px; line-height: 1.1; }
    .hero-content p { font-size: 18px; margin-bottom: 30px; letter-spacing: 1px; }
    .cta-button { display: inline-block; background: #000; color: #fff; padding: 18px 45px; text-decoration: none; border-radius: 40px; font-weight: 700; text-transform: uppercase; font-size: 14px; letter-spacing: 2px; transition: 0.3s; position: relative; z-index: 3; }
    .cta-button:hover { background: var(--secondary); color: #000; }

    .trust-badges {
        --trust-ink: #2c2825;
        --trust-muted: #5c5652;
        background: linear-gradient(180deg, #fdfcfa 0%, #f5f1eb 100%);
        border-top: 1px solid rgba(44, 40, 37, 0.06);
        border-bottom: 1px solid rgba(44, 40, 37, 0.06);
        padding: 44px 5% 48px;
    }
    .trust-badges-inner {
        max-width: 1120px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
        align-items: stretch;
    }
    .trust-badge {
        font-family: var(--font-sans);
        font-size: 14px;
        font-weight: 500;
        letter-spacing: 0.01em;
        text-transform: none;
        color: var(--trust-ink);
        line-height: 1.45;
        padding: 26px 18px 28px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        gap: 16px;
        min-width: 0;
        background: rgba(255, 255, 255, 0.72);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border-radius: 16px;
        border: 1px solid rgba(44, 40, 37, 0.06);
        box-shadow:
            0 1px 2px rgba(44, 40, 37, 0.04),
            0 12px 40px rgba(44, 40, 37, 0.06);
        transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    }
    .trust-badge:hover {
        transform: translateY(-2px);
        border-color: rgba(201, 162, 39, 0.35);
        box-shadow:
            0 2px 4px rgba(44, 40, 37, 0.05),
            0 16px 48px rgba(44, 40, 37, 0.08);
    }
    .trust-badge__icon {
        width: 56px;
        height: 56px;
        flex-shrink: 0;
        color: var(--primary);
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background: radial-gradient(circle at 30% 25%, rgba(255, 255, 255, 0.9) 0%, rgba(201, 162, 39, 0.14) 55%, rgba(201, 162, 39, 0.08) 100%);
        border: 1px solid rgba(201, 162, 39, 0.22);
    }
    .trust-badge__icon img {
        width: 26px;
        height: 26px;
        display: block;
        object-fit: contain;
    }
    .trust-badge__text {
        max-width: 15rem;
        margin: 0 auto;
        color: var(--trust-muted);
        font-weight: 500;
    }
    @media (max-width: 900px) {
        .trust-badges-inner {
            grid-template-columns: repeat(2, 1fr);
            gap: 14px;
        }
        .trust-badges { padding: 36px 5% 40px; }
        .trust-badge { padding: 22px 14px 24px; font-size: 13px; }
    }
    @media (max-width: 420px) {
        .trust-badges-inner { gap: 12px; }
        .trust-badge { padding: 20px 12px; font-size: 12.5px; }
        .trust-badge__icon { width: 50px; height: 50px; }
        .trust-badge__icon img { width: 24px; height: 24px; }
    }

    .section-container { padding: 100px 5%; text-align: center; }
    .hollow-heading {
        font-family: "Segoe Script", "Brush Script MT", cursive !important;
        font-size: clamp(30px, 6vw, 60px);
        color: #000;
        -webkit-text-stroke: 0;
        text-transform: none;
        margin-bottom: 50px;
    }

    .products-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 40px; max-width: 1200px; margin: 0 auto; }
    .product-item { text-decoration: none; color: #000; transition: 0.3s; }
    .product-item-img { width: 100%; aspect-ratio: 1; background: #f5f5f5; border-radius: 12px; margin-bottom: 20px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .product-item-img img { width: 100%; height: 100%; object-fit: cover; }
    .product-item h3 { font-family: var(--font-serif); font-size: 22px; margin-bottom: 5px; }
    .product-item p { color: #555; font-size: 14px; margin-bottom: 12px; line-height: 1.55; }
    .product-item .price { font-weight: 700; font-size: 16px; color: var(--secondary); margin-bottom: 15px; line-height: 1.4; }
    .product-btn { 
        display: inline-block; 
        background: #000; 
        color: #fff; 
        padding: 14px 22px; 
        border-radius: 50px; 
        font-size: 11px; 
        font-weight: 700; 
        text-transform: uppercase; 
        letter-spacing: 0.06em; 
        transition: 0.3s; 
        line-height: 1.35;
        max-width: 100%;
        box-sizing: border-box;
    }
    .product-item:hover .product-btn { background: var(--secondary); color: #000; }

    .section-ritual-sub {
        font-size: clamp(15px, 2.4vw, 17px);
        font-weight: 400;
        letter-spacing: 0.02em;
        color: #444;
        margin: -20px auto 48px;
        max-width: 42rem;
        line-height: 1.65;
    }

    footer {
        background: var(--primary);
        color: #fff;
        padding: 80px 5% 40px;
    }
    .footer-content {
        display: grid;
        grid-template-columns: 1.5fr 0.8fr 0.8fr 1.5fr;
        gap: 60px;
        max-width: 1400px;
        margin: 0 auto 60px;
    }
    .footer-col h3 {
        font-family: var(--font-sans);
        font-size: 14px;
        font-weight: 700;
        margin-bottom: 25px;
        color: #fff;
        text-transform: uppercase;
        letter-spacing: 2px;
    }
    .footer-newsletter h3 {
        text-transform: none;
        letter-spacing: 0.08em;
        font-size: 15px;
    }
    .footer-brand .logo {
        position: static;
        transform: none;
        color: #fff;
        display: block;
        margin-bottom: 16px;
        font-size: 28px;
    }
    .footer-brand .footer-tagline {
        font-size: 15px;
        font-weight: 600;
        color: rgba(255,255,255,0.92);
        margin-bottom: 12px;
        line-height: 1.45;
    }
    .footer-brand .footer-brand-text {
        font-size: 14px;
        line-height: 1.65;
        color: rgba(255,255,255,0.7);
        margin-bottom: 20px;
    }
    .footer-usp {
        list-style: none;
        font-size: 13px;
        color: rgba(255,255,255,0.6);
        margin-bottom: 20px;
    }
    .footer-usp li { margin-bottom: 8px; display: flex; align-items: center; gap: 10px; }
    .footer-usp li::before { content: '•'; color: var(--secondary); }
    
    .footer-social { display: flex; gap: 20px; margin-top: 20px; }
    .footer-social a { color: #fff; opacity: 0.7; transition: 0.3s; }
    .footer-social a:hover { opacity: 1; color: var(--secondary); }

    .footer-links-list { display: flex; flex-direction: column; gap: 12px; }
    .footer-links-list a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 14px; transition: 0.3s; }
    .footer-links-list a:hover { color: var(--secondary); }

    .footer-newsletter p { font-size: 14px; color: rgba(255,255,255,0.7); margin-bottom: 20px; line-height: 1.5; }
    .newsletter-form { display: flex; gap: 10px; }
    .newsletter-input {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 14px 20px;
        border-radius: 40px;
        color: #fff;
        flex: 1;
        outline: none;
        font-size: 14px;
    }
    .newsletter-input::placeholder { color: rgba(255,255,255,0.3); }
    .newsletter-btn {
        background: #fff;
        color: var(--primary);
        border: none;
        padding: 14px 30px;
        border-radius: 40px;
        font-weight: 700;
        cursor: pointer;
        transition: 0.3s;
        text-transform: uppercase;
        font-size: 13px;
        letter-spacing: 1px;
    }
    .newsletter-btn:hover { background: var(--secondary); color: #fff; }
    .footer-newsletter .newsletter-btn { text-transform: none; letter-spacing: 0.06em; }

    .footer-bottom {
        border-top: 1px solid rgba(255,255,255,0.1);
        padding-top: 30px;
        text-align: center;
        font-size: 12px;
        color: rgba(255,255,255,0.4);
        letter-spacing: 1px;
    }

    @media (max-width: 1024px) {
        .footer-content { grid-template-columns: repeat(2, 1fr); gap: 40px; }
    }
    @media (max-width: 600px) {
        .footer-content { grid-template-columns: 1fr; text-align: center; }
        .footer-usp li, .footer-social, .newsletter-form { justify-content: center; }
        .footer-links-list { align-items: center; }
    }

    @media (max-width: 768px) {
        header nav { display: none; }
        .hero {
            background-image: url("{{ 'mobile-banner.jpg' | asset_url }}");
            height: 60vh;
        }
        .header-icon-account { display: none; }
    }

    .how-it-works {
        padding: 90px 5% 100px;
        background: #fff;
        border-top: 1px solid rgba(0,0,0,0.06);
    }
    .how-it-works__inner {
        max-width: 1100px;
        margin: 0 auto;
        text-align: center;
    }
    .how-it-works__heading {
        font-family: var(--font-serif);
        font-size: clamp(28px, 5vw, 42px);
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 48px;
        line-height: 1.2;
    }
    .how-it-works__steps {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 36px;
        text-align: left;
    }
    .how-step {
        padding: 28px 24px;
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,0.08);
        background: #fafafa;
    }
    .how-step__num {
        font-family: var(--font-sans);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--secondary);
        margin-bottom: 12px;
    }
    .how-step__title {
        font-family: var(--font-serif);
        font-size: 22px;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 14px;
        line-height: 1.25;
    }
    .how-step p {
        font-size: 15px;
        line-height: 1.7;
        color: #555;
        margin: 0;
    }
    @media (max-width: 900px) {
        .how-it-works__steps { grid-template-columns: 1fr; gap: 24px; }
        .how-it-works { padding: 64px 5% 72px; }
    }

    .benefits-section {
        padding: 80px 5%;
        max-width: 1300px;
        margin: 0 auto;
        text-align: center;
    }
    .benefits-section__heading {
        font-family: var(--font-serif);
        font-size: clamp(28px, 5vw, 40px);
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 52px;
        line-height: 1.2;
    }
    .benefits-section__grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 40px 32px;
    }
    .benefit-item h3 {
        font-family: var(--font-serif);
        font-size: 22px;
        margin-bottom: 16px;
        line-height: 1.25;
        color: var(--primary);
    }
    .benefit-item p {
        color: #555;
        font-size: 15px;
        line-height: 1.7;
        max-width: 280px;
        margin: 0 auto;
    }
    @media (max-width: 1024px) {
        .benefits-section__grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
        .benefits-section {
            padding: 60px 5%;
        }
        .benefits-section__grid {
            grid-template-columns: 1fr;
            gap: 44px;
        }
    }

    .social-proof-section {
        padding: 80px 5%;
        background: #faf8f5;
        border-top: 1px solid rgba(0,0,0,0.06);
    }
    .social-proof-section__inner {
        max-width: 640px;
        margin: 0 auto;
        text-align: center;
    }
    .social-proof-section__heading {
        font-family: var(--font-serif);
        font-size: clamp(26px, 4vw, 34px);
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 28px;
        line-height: 1.2;
    }
    .social-proof-section blockquote {
        font-family: var(--font-sans);
        font-size: clamp(17px, 2.5vw, 19px);
        line-height: 1.65;
        color: #444;
        font-style: italic;
        margin: 0 0 20px;
    }
    .social-proof-section cite {
        font-family: var(--font-sans);
        font-size: 13px;
        font-style: normal;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: #666;
    }

    .faq-section {
        padding: 90px 5% 100px;
        background: #fff;
        border-top: 1px solid rgba(0,0,0,0.06);
    }
    .faq-section__inner {
        max-width: 720px;
        margin: 0 auto;
    }
    .faq-section__heading {
        font-family: var(--font-serif);
        font-size: clamp(28px, 5vw, 38px);
        font-weight: 700;
        color: var(--primary);
        text-align: center;
        margin-bottom: 40px;
        line-height: 1.2;
    }
    .faq-list details {
        border-bottom: 1px solid rgba(0,0,0,0.1);
    }
    .faq-list details:first-of-type {
        border-top: 1px solid rgba(0,0,0,0.1);
    }
    .faq-list summary {
        font-family: var(--font-sans);
        font-size: 16px;
        font-weight: 600;
        color: var(--primary);
        padding: 20px 8px 20px 0;
        cursor: pointer;
        list-style: none;
        position: relative;
        padding-right: 36px;
        line-height: 1.45;
    }
    .faq-list summary::-webkit-details-marker { display: none; }
    .faq-list summary::after {
        content: '+';
        position: absolute;
        right: 4px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 22px;
        font-weight: 400;
        color: var(--secondary);
        line-height: 1;
    }
    .faq-list details[open] summary::after { content: '−'; }
    .faq-list .faq-a {
        font-size: 15px;
        line-height: 1.7;
        color: #555;
        padding: 0 8px 22px 0;
        margin-top: -4px;
    }
    @media (max-width: 768px) {
        .faq-section { padding: 64px 5% 72px; }
    }

    .concern-section {
        padding: 100px 5%;
        text-align: center;
        background: #fff;
    }
    .concern-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        max-width: 1400px;
        margin: 0 auto;
    }
    .concern-item {
        position: relative;
        aspect-ratio: 4/5;
        background: #f7f7f7;
        background-size: cover;
        background-position: center;
        border-radius: 15px;
        overflow: hidden;
        transition: transform 0.3s ease;
    }
    .concern-item:hover { transform: translateY(-5px); }
    @media (max-width: 1024px) {
        .concern-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
        .concern-grid {
            display: flex;
            overflow-x: auto;
            gap: 15px;
            padding: 0 5% 20px;
            scroll-snap-type: x mandatory;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
        }
        .concern-grid::-webkit-scrollbar { display: none; }
        .concern-item {
            flex: 0 0 280px;
            scroll-snap-align: start;
        }
        .concern-section { padding: 60px 0; }
        .concern-section .hollow-heading { padding: 0 5%; }
    }

    .ingredients-section {
        padding: 90px 5% 100px;
        background: #faf8f5;
        border-top: 1px solid rgba(0,0,0,0.06);
    }
    .ingredients-section__inner {
        max-width: 960px;
        margin: 0 auto;
        text-align: center;
    }
    .ingredients-section__heading {
        font-family: var(--font-serif);
        font-size: clamp(28px, 5vw, 40px);
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 16px;
        line-height: 1.2;
    }
    .ingredients-section__sub {
        font-family: var(--font-sans);
        font-size: clamp(15px, 2.5vw, 17px);
        color: #666;
        margin: 0 auto 48px;
        max-width: 36rem;
        line-height: 1.55;
    }
    .ingredients-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 28px;
        text-align: left;
    }
    .ingredients-card {
        background: #fff;
        border: 1px solid rgba(0,0,0,0.08);
        border-radius: 16px;
        padding: 32px 28px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.04);
    }
    .ingredients-card h3 {
        font-family: var(--font-sans);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--primary);
        margin-bottom: 16px;
        padding-bottom: 14px;
        border-bottom: 1px solid rgba(0,0,0,0.08);
    }
    .ingredients-card p {
        font-family: var(--font-sans);
        font-size: 15px;
        line-height: 1.75;
        color: #444;
        margin: 0;
    }
    .ingredients-section__safety {
        font-family: var(--font-sans);
        font-size: 14px;
        color: #555;
        margin: 44px auto 0;
        padding-top: 36px;
        border-top: 1px solid rgba(0,0,0,0.1);
        max-width: 40rem;
        line-height: 1.6;
    }
    @media (max-width: 768px) {
        .ingredients-section { padding: 64px 5% 72px; }
        .ingredients-grid { grid-template-columns: 1fr; gap: 20px; }
        .ingredients-card { padding: 26px 22px; }
    }
