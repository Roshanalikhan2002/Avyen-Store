{% comment %}
  Avyen - Premium Cart Page Template
{% endcomment %}

<style>
    :root {
        --primary: #121212;
        --secondary: #c9a227;
        --background: #ffffff;
        --text: #121212;
        --font-serif: 'Playfair Display', serif;
        --font-sans: 'Inter', sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--font-sans); color: var(--text); background: var(--background); overflow-x: hidden; }

    .announcement-bar { background: #000; color: #fff; text-align: center; padding: 10px 0; font-size: 12px; text-transform: uppercase; letter-spacing: 2px; }

    header { 
        display: flex; justify-content: space-between; align-items: center; 
        padding: 20px 5%; border-bottom: 1px solid #eee; background: #fff;
        position: sticky; top: 0; z-index: 1000;
    }
    .logo { 
        font-family: var(--font-serif); font-size: 28px; font-weight: 700; 
        color: var(--primary); text-decoration: none; letter-spacing: 4px;
        position: absolute; left: 50%; transform: translateX(-50%);
    }
    nav { display: flex; flex-wrap: wrap; align-items: center; gap: 6px 10px; max-width: 44%; }
    nav a { text-decoration: none; color: #000; font-weight: 600; font-size: 11px; text-transform: uppercase; margin: 0; letter-spacing: 0.5px; white-space: nowrap; }
    .header-icons { display: flex; gap: 16px; align-items: center; }
    .menu-btn { display: none; cursor: pointer; }

    .mobile-drawer {
        position: fixed; top: 0; left: -100%; width: 80%; max-width: 350px; height: 100%;
        background: #fff; z-index: 2000; transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex; flex-direction: column; box-shadow: 20px 0 60px rgba(0,0,0,0.1); overflow-y: auto;
    }
    .mobile-drawer.active { left: 0; }
    .drawer-header { background: var(--primary); padding: 60px 30px 40px; position: relative; }
    .drawer-logo { font-family: var(--font-serif); font-size: 32px; color: #fff; font-weight: 700; letter-spacing: 4px; margin-bottom: 10px; }
    .drawer-subtitle { color: rgba(255,255,255,0.6); font-size: 13px; letter-spacing: 1px; }
    .drawer-close { color: #fff; position: absolute; top: 20px; right: 20px; font-size: 28px; cursor: pointer; }
    .drawer-links { padding: 20px 0; }
    .drawer-link {
        display: flex; align-items: center; gap: 20px; padding: 18px 30px; text-decoration: none;
        color: var(--primary); font-weight: 700; font-size: 14px; letter-spacing: 1px;
    }
    .drawer-link svg { width: 20px; height: 20px; opacity: 0.6; }
    .drawer-link.active { background: #f5f5f5; }
    .drawer-sep { padding: 30px 30px 15px; font-size: 11px; font-weight: 700; color: #bbb; text-transform: uppercase; letter-spacing: 2px; }
    .drawer-overlay {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.4); backdrop-filter: blur(4px); z-index: 1999;
        opacity: 0; visibility: hidden; transition: 0.3s;
    }
    .drawer-overlay.active { opacity: 1; visibility: visible; }

    .cart-container { max-width: 1200px; margin: 80px auto; padding: 0 5%; }
    .cart-header { text-align: center; margin-bottom: 60px; }
    .cart-header h1 { font-family: var(--font-serif); font-size: 48px; margin-bottom: 10px; }
    
    .cart-empty { text-align: center; padding: 100px 0; }
    .cart-empty p { font-size: 18px; color: #666; margin-bottom: 30px; }
    .shop-btn { 
        display: inline-block; background: var(--primary); color: #fff; 
        padding: 18px 45px; border-radius: 40px; text-decoration: none; 
        font-weight: 700; text-transform: uppercase; font-size: 14px; letter-spacing: 2px;
    }

    .cart-table { width: 100%; border-collapse: collapse; margin-bottom: 40px; }
    .cart-table th { text-align: left; padding: 20px 0; border-bottom: 2px solid #eee; text-transform: uppercase; font-size: 12px; letter-spacing: 1px; color: #999; }
    .cart-table td { padding: 30px 0; border-bottom: 1px solid #eee; }

    .cart-product { display: flex; align-items: center; gap: 20px; }
    .cart-product-img { width: 100px; height: 100px; border-radius: 8px; overflow: hidden; background: #f9f9f9; }
    .cart-product-img img { width: 100%; height: 100%; object-fit: cover; }
    .cart-product-info h3 { font-family: var(--font-serif); font-size: 20px; margin-bottom: 5px; }
    .cart-product-info p { font-size: 14px; color: #666; }

    .qty-control { display: flex; align-items: center; gap: 15px; border: 1px solid #eee; padding: 8px 15px; border-radius: 30px; width: fit-content; }
    .qty-btn { background: none; border: none; cursor: pointer; font-size: 18px; color: #000; }
    .qty-num { font-weight: 600; width: 20px; text-align: center; }

    .cart-summary { background: #f9f9f9; padding: 40px; border-radius: 20px; margin-left: auto; max-width: 450px; }
    .summary-row { display: flex; justify-content: space-between; margin-bottom: 20px; font-size: 16px; }
    .summary-total { border-top: 1px solid #ddd; padding-top: 20px; font-weight: 700; font-size: 22px; }
    
    .checkout-btn { 
        display: block; width: 100%; background: var(--primary); color: #fff; 
        padding: 20px; border-radius: 40px; text-decoration: none; text-align: center;
        font-weight: 700; text-transform: uppercase; font-size: 15px; letter-spacing: 2px;
        margin-top: 30px; transition: 0.3s;
    }
    .checkout-btn:hover { background: var(--secondary); color: #fff; }

    @media (max-width: 768px) {
        .announcement-bar { font-size: 10px; padding: 12px 3%; white-space: normal; line-height: 1.35; }
        header { justify-content: flex-end; }
        nav { display: none; }
        .menu-btn { display: block; position: absolute; left: 5%; }
        .logo { font-size: 24px; letter-spacing: 2px; }
        .cart-table thead { display: none; }
        .cart-table tr { display: flex; flex-direction: column; gap: 15px; padding: 30px 0; }
        .cart-table td { padding: 0; border: none; }
        .cart-summary { max-width: 100%; }
    }
</style>

