<main class="cart-container">
    {% if cart.item_count > 0 %}
        <div class="cart-header">
            <h1>Your Ritual</h1>
            <p>{{ cart.item_count }} items in your cart</p>
        </div>

        <form action="/cart" method="post" novalidate>
            <table class="cart-table">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in cart.items %}
                        <tr>
                            <td>
                                <div class="cart-product">
                                    <div class="cart-product-img">
                                        <img src="{{ item | img_url: '200x200' }}" alt="{{ item.title }}">
                                    </div>
                                    <div class="cart-product-info">
                                        <h3>{{ item.product.title }}</h3>
                                        <a href="/cart/change?line={{ forloop.index }}&quantity=0" style="font-size:12px; color:#e74c3c;">Remove</a>
                                    </div>
                                </div>
                            </td>
                            <td>{{ item.price | money }}</td>
                            <td>
                                <div class="qty-control">
                                    <a href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | minus: 1 }}" class="qty-btn">−</a>
                                    <span class="qty-num">{{ item.quantity }}</span>
                                    <a href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | plus: 1 }}" class="qty-btn">+</a>
                                </div>
                            </td>
                            <td>{{ item.line_price | money }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>

            <div class="cart-summary">
                <div class="summary-row">
                    <span>Subtotal</span>
                    <span>{{ cart.total_price | money }}</span>
                </div>
                <div class="summary-row">
                    <span>Shipping</span>
                    <span>Calculated at checkout</span>
                </div>
                <div class="summary-row summary-total">
                    <span>Total</span>
                    <span>{{ cart.total_price | money }}</span>
                </div>
                <button type="submit" name="checkout" class="checkout-btn">Proceed to Checkout</button>
            </div>
        </form>
    {% else %}
        <div class="cart-empty">
            <p>Your cart is currently empty.</p>
            <a href="/collections/all" class="shop-btn">Start Shopping</a>
        </div>
    {% endif %}
</main>

<script>
    function toggleMenu() {
        document.getElementById('mobileDrawer').classList.toggle('active');
        document.querySelector('.drawer-overlay').classList.toggle('active');
    }
</script>
