{% comment %}
  Avyen - Collection Template
{% endcomment %}

<style>
    :root {
        --primary: #121212;
        --secondary: #c9a227;
        --background: #ffffff;
        --border: #f0f0f0;
        --font-serif: 'Playfair Display', serif;
        --font-sans: 'Inter', sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--font-sans); color: var(--primary); background: var(--background); overflow-x: hidden; }

    header { display: flex; justify-content: space-between; align-items: center; padding: 20px 5%; border-bottom: 1px solid #eee; position: sticky; top: 0; background: #fff; z-index: 1000; }
    .logo { font-family: var(--font-serif); font-size: 32px; font-weight: 700; color: var(--primary); text-decoration: none; letter-spacing: 4px; position: absolute; left: 50%; transform: translateX(-50%); }
    nav { display: flex; flex-wrap: wrap; align-items: center; gap: 6px 10px; max-width: 44%; }
    nav a { text-decoration: none; color: #000; font-weight: 600; font-size: 11px; text-transform: uppercase; margin: 0; letter-spacing: 0.5px; white-space: nowrap; }
    .header-icons { display: flex; gap: 20px; }

    @media (max-width: 768px) {
        header { justify-content: flex-end; }
        nav { display: none; }
        .menu-btn { display: block; position: absolute; left: 5%; }
        .logo { font-size: 24px; letter-spacing: 2px; }
    }

    .menu-btn { display: none; cursor: pointer; }
    
    .mobile-drawer {
        position: fixed;
        top: 0;
        left: -100%;
        width: 80%;
        max-width: 350px;
        height: 100%;
        background: #fff;
        z-index: 2000;
        transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        box-shadow: 20px 0 60px rgba(0,0,0,0.1);
        overflow-y: auto;
    }
    .mobile-drawer.active { left: 0; }
    
    .drawer-header {
        background: var(--primary);
        padding: 60px 30px 40px;
        position: relative;
    }
    .drawer-logo {
        font-family: var(--font-serif);
        font-size: 32px;
        color: #fff;
        font-weight: 700;
        letter-spacing: 4px;
        margin-bottom: 10px;
    }
    .drawer-subtitle {
        color: rgba(255,255,255,0.6);
        font-size: 13px;
        letter-spacing: 1px;
    }
    .drawer-close {
        color: #fff;
        position: absolute;
        top: 20px;
        right: 20px;
        font-size: 28px;
        cursor: pointer;
    }
    .drawer-links {
        padding: 20px 0;
    }
    .drawer-link {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 18px 30px;
        text-decoration: none;
        color: var(--primary);
        font-weight: 700;
        font-size: 14px;
        letter-spacing: 1px;
        transition: 0.3s;
    }
    .drawer-link svg {
        width: 20px;
        height: 20px;
        opacity: 0.6;
    }
    .drawer-link.active {
        background: #f5f5f5;
        color: var(--primary);
    }
    .drawer-link:hover {
        background: #fafafa;
    }
    .drawer-sep {
        padding: 30px 30px 15px;
        font-size: 11px;
        font-weight: 700;
        color: #bbb;
        text-transform: uppercase;
        letter-spacing: 2px;
    }
    .drawer-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.4);
        backdrop-filter: blur(4px);
        z-index: 1999;
        opacity: 0;
        visibility: hidden;
        transition: 0.3s;
    }
    .drawer-overlay.active { opacity: 1; visibility: visible; }

    .collection-header { padding: 120px 5% 80px; text-align: center; background: #fff; }
    .collection-header h1 { font-family: var(--font-serif); font-size: clamp(40px, 6vw, 64px); margin-bottom: 25px; color: var(--primary); }
    .collection-header p { font-size: 18px; color: #666; max-width: 650px; margin: 0 auto; line-height: 1.6; }

    .collection-grid { 
        padding: 40px 5% 120px; 
        display: grid; 
        grid-template-columns: repeat(2, 1fr); 
        gap: 40px; 
        max-width: 1100px; 
        margin: 0 auto; 
    }
    .product-card { text-decoration: none; color: #000; }
    .product-card-img { 
        width: 100%; 
        aspect-ratio: 1; 
        background: #f9f9f9; 
        border-radius: 15px; 
        overflow: hidden; 
        margin-bottom: 25px; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        transition: 0.5s cubic-bezier(0.4, 0, 0.2, 1); 
    }
    .product-card-img img { width: 100%; height: 100%; object-fit: cover; transition: 0.8s ease; }
    .product-card:hover .product-card-img { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.05); }
    .product-card:hover img { transform: scale(1.05); }
    
    .product-card h3 { font-family: var(--font-serif); font-size: 24px; margin-bottom: 8px; }
    .product-card p { font-size: 14px; color: #555; margin-bottom: 14px; line-height: 1.55; letter-spacing: 0.02em; text-transform: none; }
    .product-card .price { font-weight: 700; font-size: 15px; color: var(--secondary); line-height: 1.35; }

    .view-details-btn {
        display: inline-block;
        margin-top: 15px;
        padding: 10px 25px;
        background: #000;
        color: #fff;
        text-decoration: none;
        font-weight: 700;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-radius: 40px;
        transition: 0.3s;
    }
    .view-details-btn:hover {
        background: var(--secondary);
        color: #000;
    }

    @media (max-width: 768px) {
        .collection-grid { grid-template-columns: 1fr; gap: 60px; }
        .collection-header { padding: 80px 5% 40px; }
        header nav { display: none; }
        .header-icon-account { display: none; }
    }

    footer {
        background: var(--primary);
        color: #fff;
        padding: 80px 5% 40px;
    }
    .footer-content {
        display: grid;
        grid-template-columns: 1.5fr 0.8fr 0.8fr 1.5fr;
        gap: 60px;
        max-width: 1400px;
        margin: 0 auto 60px;
    }
    .footer-col h3 {
        font-family: var(--font-sans);
        font-size: 14px;
        font-weight: 700;
        margin-bottom: 25px;
        color: #fff;
        text-transform: uppercase;
        letter-spacing: 2px;
    }
    .footer-newsletter h3 {
        text-transform: none;
        letter-spacing: 0.08em;
        font-size: 15px;
    }
    .footer-brand .footer-logo {
        color: #fff;
        display: block;
        margin-bottom: 16px;
        font-size: 28px;
        font-family: var(--font-serif);
        text-decoration: none;
        letter-spacing: 4px;
        font-weight: 700;
    }
    .footer-brand .footer-tagline {
        font-size: 15px;
        font-weight: 600;
        color: rgba(255,255,255,0.92);
        margin-bottom: 12px;
        line-height: 1.45;
    }
    .footer-brand .footer-brand-text {
        font-size: 14px;
        line-height: 1.65;
        color: rgba(255,255,255,0.7);
        margin-bottom: 20px;
    }
    .footer-usp {
        list-style: none;
        font-size: 13px;
        color: rgba(255,255,255,0.6);
        margin-bottom: 20px;
    }
    .footer-usp li { margin-bottom: 8px; display: flex; align-items: center; gap: 10px; }
    .footer-usp li::before { content: '•'; color: var(--secondary); }
    
    .footer-social { display: flex; gap: 20px; margin-top: 20px; }
    .footer-social a { color: #fff; opacity: 0.7; transition: 0.3s; }
    .footer-social a:hover { opacity: 1; color: var(--secondary); }

    .footer-links-list { display: flex; flex-direction: column; gap: 12px; }
    .footer-links-list a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 14px; transition: 0.3s; }
    .footer-links-list a:hover { color: var(--secondary); }

    .footer-newsletter p { font-size: 14px; color: rgba(255,255,255,0.7); margin-bottom: 20px; line-height: 1.5; }
    .newsletter-form { display: flex; gap: 10px; }
    .newsletter-input {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 14px 20px;
        border-radius: 40px;
        color: #fff;
        flex: 1;
        outline: none;
        font-size: 14px;
    }
    .newsletter-input::placeholder { color: rgba(255,255,255,0.3); }
    .newsletter-btn {
        background: #fff;
        color: var(--primary);
        border: none;
        padding: 14px 30px;
        border-radius: 40px;
        font-weight: 700;
        cursor: pointer;
        transition: 0.3s;
        text-transform: uppercase;
        font-size: 13px;
        letter-spacing: 1px;
    }
    .newsletter-btn:hover { background: var(--secondary); color: #fff; }
    .footer-newsletter .newsletter-btn { text-transform: none; letter-spacing: 0.06em; }

    .footer-bottom {
        border-top: 1px solid rgba(255,255,255,0.1);
        padding-top: 30px;
        text-align: center;
        font-size: 12px;
        color: rgba(255,255,255,0.4);
        letter-spacing: 1px;
    }

    @media (max-width: 1024px) {
        .footer-content { grid-template-columns: repeat(2, 1fr); gap: 40px; }
    }
    @media (max-width: 600px) {
        .footer-content { grid-template-columns: 1fr; text-align: center; }
        .footer-usp li, .footer-social, .newsletter-form { justify-content: center; }
        .footer-links-list { align-items: center; }
    }
</style>

