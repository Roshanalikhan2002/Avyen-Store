{% comment %}
  Avyen - Contact Page Template
{% endcomment %}

<style>
    :root {
        --primary: #121212;
        --secondary: #c9a227;
        --background: #ffffff;
        --font-serif: 'Playfair Display', serif;
        --font-sans: 'Inter', sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--font-sans); color: var(--primary); background: var(--background); overflow-x: hidden; }

    .announcement-bar { background: #000; color: #fff; text-align: center; padding: 10px 0; font-size: 12px; text-transform: uppercase; letter-spacing: 2px; }
    @media (max-width: 768px) {
        .announcement-bar { font-size: 10px; padding: 12px 2%; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    }

    header { display: flex; justify-content: space-between; align-items: center; padding: 20px 5%; border-bottom: 1px solid #eee; position: sticky; top: 0; background: #fff; z-index: 1000; }
    .logo { font-family: var(--font-serif); font-size: 32px; font-weight: 700; color: var(--primary); text-decoration: none; letter-spacing: 4px; position: absolute; left: 50%; transform: translateX(-50%); }
    nav a { text-decoration: none; color: #000; font-weight: 600; font-size: 13px; text-transform: uppercase; margin: 0 15px; letter-spacing: 1px; }
    .header-icons { display: flex; gap: 20px; }

    .menu-btn { display: none; cursor: pointer; }
    @media (max-width: 768px) {
        header { justify-content: flex-end; }
        nav { display: none; }
        .menu-btn { display: block; position: absolute; left: 5%; }
        .logo { font-size: 24px; letter-spacing: 2px; }
    }

    .mobile-drawer {
        position: fixed;
        top: 0;
        left: -100%;
        width: 80%;
        max-width: 350px;
        height: 100%;
        background: #fff;
        z-index: 2000;
        transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        box-shadow: 20px 0 60px rgba(0,0,0,0.1);
    }
    .mobile-drawer.active { left: 0; }
    .drawer-header { background: var(--primary); padding: 60px 30px 40px; position: relative; }
    .drawer-logo { font-family: var(--font-serif); font-size: 32px; color: #fff; font-weight: 700; letter-spacing: 4px; margin-bottom: 10px; }
    .drawer-subtitle { color: rgba(255,255,255,0.6); font-size: 13px; letter-spacing: 1px; }
    .drawer-close { color: #fff; position: absolute; top: 20px; right: 20px; font-size: 28px; cursor: pointer; }
    .drawer-links { padding: 20px 0; }
    .drawer-link { display: flex; align-items: center; gap: 20px; padding: 18px 30px; text-decoration: none; color: var(--primary); font-weight: 700; font-size: 14px; letter-spacing: 1px; }
    .drawer-link svg { width: 20px; height: 20px; opacity: 0.6; }
    .drawer-sep { padding: 30px 30px 15px; font-size: 11px; font-weight: 700; color: #bbb; text-transform: uppercase; letter-spacing: 2px; }

    .contact-container { max-width: 1200px; margin: 0 auto; padding: 100px 5%; display: grid; grid-template-columns: 1fr 1.5fr; gap: 80px; }
    .contact-info h1 { font-family: var(--font-serif); font-size: 54px; margin-bottom: 30px; line-height: 1.1; }
    .contact-info p { font-size: 18px; color: #666; margin-bottom: 40px; line-height: 1.6; }
    
    .info-item { margin-bottom: 30px; }
    .info-item h3 { font-size: 12px; text-transform: uppercase; letter-spacing: 2px; color: var(--secondary); margin-bottom: 10px; }
    .info-item p { font-size: 16px; color: var(--primary); margin: 0; }

    .contact-form-wrapper { background: #f9f9f9; padding: 60px; border-radius: 20px; }
    .form-group { margin-bottom: 25px; }
    .form-group label { display: block; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; }
    .form-input { 
        width: 100%; 
        padding: 18px 25px; 
        border: 1px solid #ddd; 
        border-radius: 12px; 
        font-family: var(--font-sans); 
        font-size: 15px; 
        outline: none; 
        transition: 0.3s; 
        background: #fff;
    }
    .form-input:focus { border-color: var(--primary); }
    textarea.form-input { height: 150px; resize: none; }
    
    .submit-btn { 
        width: 100%; 
        background: var(--primary); 
        color: #fff; 
        padding: 22px; 
        border: none; 
        border-radius: 50px; 
        font-weight: 700; 
        text-transform: uppercase; 
        letter-spacing: 2px; 
        cursor: pointer; 
        transition: 0.3s; 
    }
    .submit-btn:hover { background: var(--secondary); color: #000; }

    @media (max-width: 900px) {
        .contact-container { grid-template-columns: 1fr; gap: 60px; padding: 60px 5%; }
        .contact-info h1 { font-size: 42px; }
        .contact-form-wrapper { padding: 40px; }
    }

    footer { background: var(--primary); color: #fff; padding: 80px 5% 40px; }
    .footer-content { display: grid; grid-template-columns: 1.5fr 0.8fr 0.8fr 1.5fr; gap: 60px; max-width: 1400px; margin: 0 auto 60px; }
    .footer-col h3 { font-size: 14px; font-weight: 700; margin-bottom: 25px; text-transform: uppercase; letter-spacing: 2px; }
    .footer-brand .footer-logo { color: #fff; display: block; margin-bottom: 20px; font-size: 28px; font-family: var(--font-serif); text-decoration: none; letter-spacing: 4px; font-weight: 700; }
    .footer-brand p { font-size: 14px; line-height: 1.6; color: rgba(255,255,255,0.7); margin-bottom: 20px; }
    .footer-links-list { display: flex; flex-direction: column; gap: 12px; }
    .footer-links-list a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 14px; transition: 0.3s; }
    .footer-links-list a:hover { color: var(--secondary); }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 30px; text-align: center; font-size: 12px; color: rgba(255,255,255,0.4); }
</style>

<div class="announcement-bar">Elevate Your Hair Ritual — Free Shipping On All Sets</div>

<header>
    <div class="menu-btn" onclick="toggleMenu()">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    </div>
    <nav><a href="/">Home</a><a href="/collections/all">Shop</a></nav>
    <a href="/" class="logo">AVYEN</a>
    <div class="header-icons">
        <a href="#" onclick="gOpenCart()" style="color:#000;"><svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M16 10a4 4 0 0 1-8 0"></path></svg></a>
    </div>
</header>

<div class="drawer-overlay" onclick="toggleMenu()"></div>
<div class="mobile-drawer" id="mobileDrawer">
    <div class="drawer-header">
        <div class="drawer-logo">AVYEN</div>
        <div class="drawer-subtitle">Excellence in Every Strand</div>
        <div class="drawer-close" onclick="toggleMenu()">×</div>
    </div>
    <div class="drawer-links">
        <a href="/" class="drawer-link">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
            HOME
        </a>
        <a href="/collections/all" class="drawer-link">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
            SHOP
        </a>
        
        <div class="drawer-sep">COMMUNICATE</div>
        
        <a href="/pages/contact" class="drawer-link active">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            CONTACT
        </a>
    </div>
</div>

<main>
    <div class="contact-container">
        <div class="contact-info">
            <h1>Get in Touch</h1>
            <p>Have a question about our rituals or your order? Our concierge team is here to assist you.</p>
            
            <div class="info-item">
                <h3>Support Email</h3>
                <p>care@avyen.com</p>
            </div>
            <div class="info-item">
                <h3>Operating Hours</h3>
                <p>Monday - Saturday: 10am - 7pm</p>
            </div>
            <div class="info-item">
                <h3>Location</h3>
                <p>Lahore, Pakistan</p>
            </div>
        </div>

        <div class="contact-form-wrapper">
            {% form 'contact' %}
                {% if form.posted_successfully? %}
                    <div style="background:#e8f5e9; color:#2e7d32; padding:20px; border-radius:12px; margin-bottom:30px; font-weight:700;">
                        Thank you for your message. We will get back to you shortly.
                    </div>
                {% endif %}

                <div class="form-group">
                    <label for="ContactFormName">Name</label>
                    <input type="text" id="ContactFormName" name="contact[name]" class="form-input" placeholder="Your Name" required>
                </div>

                <div class="form-group">
                    <label for="ContactFormEmail">Email</label>
                    <input type="email" id="ContactFormEmail" name="contact[email]" class="form-input" placeholder="Email Address" required>
                </div>

                <div class="form-group">
                    <label for="ContactFormPhone">Phone (Optional)</label>
                    <input type="tel" id="ContactFormPhone" name="contact[phone]" class="form-input" placeholder="Phone Number">
                </div>

                <div class="form-group">
                    <label for="ContactFormMessage">Message</label>
                    <textarea id="ContactFormMessage" name="contact[body]" class="form-input" placeholder="How can we help?" required></textarea>
                </div>

                <button type="submit" class="submit-btn">Send Message</button>
            {% endform %}
        </div>
    </div>
</main>

<footer>
    <div class="footer-content">
        <div class="footer-col footer-brand">
            <a href="/" class="footer-logo">AVYEN</a>
            <p>Redefining hair care through the fusion of botanical purity and scientific precision.</p>
        </div>
        <div class="footer-col">
            <h3>Shop</h3>
            <div class="footer-links-list">
                <a href="/collections/all">All Products</a>
            </div>
        </div>
        <div class="footer-col">
            <h3>Help</h3>
            <div class="footer-links-list">
                <a href="/pages/contact">Contact Us</a>
            </div>
        </div>
        <div class="footer-col">
            <h3>Social</h3>
            <div class="footer-links-list">
                <a href="#">Instagram</a>
                <a href="#">Facebook</a>
            </div>
        </div>
    </div>
    <div class="footer-bottom">&copy; 2024 AVYEN. All rights reserved.</div>
</footer>

<script>
    function toggleMenu() {
        document.getElementById('mobileDrawer').classList.toggle('active');
        document.querySelector('.drawer-overlay').classList.toggle('active');
    }
</script>
