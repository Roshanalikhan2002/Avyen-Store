<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if template.name == 'index' %}AVYEN{% elsif page_title != blank %}{{ page_title }} | AVYEN{% else %}AVYEN{% endif %}</title>
    {% comment %} Old / bookmarked URL: Shopify page handle is shipping-delivery-policy {% endcomment %}
    {% assign _req_path = request.path | strip | downcase %}
    {% if _req_path == '/pages/shipping-policy' or _req_path == '/pages/shipping-policy/' %}
    <meta http-equiv="refresh" content="0; url={{ shop.url }}/pages/shipping-delivery-policy">
    <script>window.location.replace({{ '/pages/shipping-delivery-policy' | json }});</script>
    {% elsif _req_path == '/pages/refund-policy' or _req_path == '/pages/refund-policy/' %}
    <meta http-equiv="refresh" content="0; url={{ shop.url }}/pages/return-and-refund-policy">
    <script>window.location.replace({{ '/pages/return-and-refund-policy' | json }});</script>
    {% elsif _req_path == '/pages/return-refund-policy' or _req_path == '/pages/return-refund-policy/' %}
    <meta http-equiv="refresh" content="0; url={{ shop.url }}/pages/return-and-refund-policy">
    <script>window.location.replace({{ '/pages/return-and-refund-policy' | json }});</script>
    {% endif %}
    {{ content_for_header }}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">

    <style>
        body, html { margin: 0; padding: 0; width: 100%; }

        /* Navbar logo image — tight crop + larger display */
        header a.logo.site-logo {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            line-height: 0;
            text-decoration: none;
            z-index: 2;
        }
        header a.logo.site-logo .site-logo__img {
            display: block;
            height: 56px !important;
            width: auto !important;
            max-width: none !important;
            min-width: 140px;
            object-fit: contain;
        }
        @media (max-width: 768px) {
            header a.logo.site-logo .site-logo__img {
                height: 40px !important;
                min-width: 100px;
            }
        }

        /* Mobile sticky add-to-cart (product pages) */
        .sticky-mobile-atc {
            display: none;
        }
        @media (max-width: 768px) {
            .sticky-mobile-atc {
                display: block;
                position: fixed;
                left: 0;
                right: 0;
                bottom: 0;
                z-index: 950;
                padding: 12px 16px calc(12px + env(safe-area-inset-bottom, 0px));
                background: rgba(255, 255, 255, 0.98);
                border-top: 1px solid #eee;
                box-shadow: 0 -8px 32px rgba(0, 0, 0, 0.08);
                backdrop-filter: blur(10px);
            }
            .sticky-mobile-atc__inner {
                display: flex;
                align-items: center;
                gap: 12px;
                max-width: 560px;
                margin: 0 auto;
            }
            .sticky-mobile-atc__meta {
                flex: 1;
                min-width: 0;
                margin: 0;
                line-height: 1.25;
            }
            .sticky-mobile-atc__title {
                display: block;
                font-size: 12px;
                font-weight: 700;
                color: #121212;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }
            .sticky-mobile-atc__price {
                display: block;
                font-size: 11px;
                font-weight: 600;
                color: #666;
                margin-top: 2px;
            }
            .sticky-mobile-atc__btn {
                flex-shrink: 0;
                min-width: 52%;
                max-width: 220px;
                background: #000;
                color: #fff;
                border: none;
                border-radius: 50px;
                padding: 14px 18px;
                font-weight: 700;
                font-size: 12px;
                line-height: 1.2;
                text-align: center;
                text-decoration: none;
                cursor: pointer;
                letter-spacing: 0.02em;
                box-sizing: border-box;
                -webkit-tap-highlight-color: transparent;
            }
            .sticky-mobile-atc__btn:active {
                opacity: 0.9;
            }
            .sticky-mobile-atc + footer {
                padding-bottom: calc(40px + 88px + env(safe-area-inset-bottom, 0px));
            }
            .global-cart-drawer.active ~ .sticky-mobile-atc,
            body:has(.global-cart-drawer.active) .sticky-mobile-atc {
                z-index: 900;
            }
            body:has(.sticky-mobile-atc) .g-atc-toast.show {
                bottom: calc(100px + env(safe-area-inset-bottom, 0px));
            }
            /* Homepage sticky ATC — hide while #shop product cards are in view */
            #homeStickyAtc .sticky-mobile-atc {
                transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.35s ease, visibility 0.35s ease;
            }
            #homeStickyAtc.is-hidden .sticky-mobile-atc {
                transform: translateY(110%);
                opacity: 0;
                visibility: hidden;
                pointer-events: none;
            }
            body:has(#homeStickyAtc:not(.is-hidden)) footer {
                padding-bottom: calc(40px + 88px + env(safe-area-inset-bottom, 0px));
            }
        }

        /* Animated order flow (product + cart) */
        .order-flow {
            margin: 28px 0 32px;
            padding: 22px 20px 20px;
            background: #faf8f5;
            border: 1px solid rgba(201, 162, 39, 0.22);
            border-radius: 14px;
            max-width: 520px;
        }
        .order-flow__title {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.16em;
            text-transform: uppercase;
            color: #121212;
            margin: 0 0 18px;
            text-align: center;
        }
        .order-flow__track { position: relative; padding: 8px 4px 0; }
        .order-flow__line {
            position: absolute;
            left: 12%;
            right: 12%;
            top: 22px;
            height: 3px;
            background: #e5e0d8;
            border-radius: 3px;
            overflow: hidden;
            z-index: 0;
        }
        .order-flow__line-fill {
            display: block;
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, #c9a227, #e8c96a);
            border-radius: 3px;
            transition: width 0.65s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .order-flow[data-step="1"] .order-flow__line-fill { width: 0%; }
        .order-flow[data-step="2"] .order-flow__line-fill { width: 33.33%; }
        .order-flow[data-step="3"] .order-flow__line-fill { width: 66.66%; }
        .order-flow[data-step="4"] .order-flow__line-fill { width: 100%; }
        .order-flow__steps {
            list-style: none;
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: space-between;
            position: relative;
            z-index: 1;
        }
        .order-flow__step {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            text-align: center;
            min-width: 0;
        }
        .order-flow__dot {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: #fff;
            border: 2px solid #ddd;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: border-color 0.4s, background 0.4s, transform 0.4s, box-shadow 0.4s;
        }
        .order-flow__dot-inner {
            font-size: 13px;
            font-weight: 700;
            color: #999;
            transition: color 0.35s;
        }
        .order-flow__label {
            font-size: 10px;
            font-weight: 600;
            color: #888;
            line-height: 1.25;
            padding: 0 2px;
            transition: color 0.35s;
        }
        .order-flow__step[data-flow-step] .order-flow__dot-inner::after { content: none; }
        .order-flow[data-step="2"] .order-flow__step[data-flow-step="1"] .order-flow__dot,
        .order-flow[data-step="3"] .order-flow__step[data-flow-step="1"] .order-flow__dot,
        .order-flow[data-step="3"] .order-flow__step[data-flow-step="2"] .order-flow__dot,
        .order-flow[data-step="4"] .order-flow__step[data-flow-step="1"] .order-flow__dot,
        .order-flow[data-step="4"] .order-flow__step[data-flow-step="2"] .order-flow__dot,
        .order-flow[data-step="4"] .order-flow__step[data-flow-step="3"] .order-flow__dot {
            border-color: #c9a227;
            background: #121212;
        }
        .order-flow[data-step="2"] .order-flow__step[data-flow-step="1"] .order-flow__dot-inner,
        .order-flow[data-step="3"] .order-flow__step[data-flow-step="1"] .order-flow__dot-inner,
        .order-flow[data-step="3"] .order-flow__step[data-flow-step="2"] .order-flow__dot-inner,
        .order-flow[data-step="4"] .order-flow__step[data-flow-step="1"] .order-flow__dot-inner,
        .order-flow[data-step="4"] .order-flow__step[data-flow-step="2"] .order-flow__dot-inner,
        .order-flow[data-step="4"] .order-flow__step[data-flow-step="3"] .order-flow__dot-inner {
            color: #fff;
            font-size: 0;
        }
        .order-flow[data-step="2"] .order-flow__step[data-flow-step="1"] .order-flow__dot-inner::before,
        .order-flow[data-step="3"] .order-flow__step[data-flow-step="1"] .order-flow__dot-inner::before,
        .order-flow[data-step="3"] .order-flow__step[data-flow-step="2"] .order-flow__dot-inner::before,
        .order-flow[data-step="4"] .order-flow__step[data-flow-step="1"] .order-flow__dot-inner::before,
        .order-flow[data-step="4"] .order-flow__step[data-flow-step="2"] .order-flow__dot-inner::before,
        .order-flow[data-step="4"] .order-flow__step[data-flow-step="3"] .order-flow__dot-inner::before {
            content: '✓';
            font-size: 16px;
            font-weight: 700;
        }
        .order-flow[data-step="1"] .order-flow__step[data-flow-step="1"] .order-flow__dot,
        .order-flow[data-step="2"] .order-flow__step[data-flow-step="2"] .order-flow__dot,
        .order-flow[data-step="3"] .order-flow__step[data-flow-step="3"] .order-flow__dot,
        .order-flow[data-step="4"] .order-flow__step[data-flow-step="4"] .order-flow__dot {
            border-color: #c9a227;
            box-shadow: 0 0 0 4px rgba(201, 162, 39, 0.2);
            transform: scale(1.06);
            animation: order-flow-pulse 1.6s ease-in-out infinite;
        }
        .order-flow[data-step="4"] .order-flow__step[data-flow-step="4"] .order-flow__dot {
            background: #121212;
            animation: order-flow-pop 0.6s ease;
        }
        .order-flow[data-step="4"] .order-flow__step[data-flow-step="4"] .order-flow__dot-inner {
            color: #fff;
            font-size: 0;
        }
        .order-flow[data-step="4"] .order-flow__step[data-flow-step="4"] .order-flow__dot-inner::before {
            content: '✓';
            font-size: 18px;
        }
        .order-flow[data-step="1"] .order-flow__step[data-flow-step="1"] .order-flow__label,
        .order-flow[data-step="2"] .order-flow__step[data-flow-step="2"] .order-flow__label,
        .order-flow[data-step="3"] .order-flow__step[data-flow-step="3"] .order-flow__label,
        .order-flow[data-step="4"] .order-flow__step[data-flow-step="4"] .order-flow__label {
            color: #121212;
            font-weight: 700;
        }
        .order-flow[data-step="2"] .order-flow__step[data-flow-step="1"] .order-flow__label,
        .order-flow[data-step="3"] .order-flow__step[data-flow-step="1"] .order-flow__label,
        .order-flow[data-step="3"] .order-flow__step[data-flow-step="2"] .order-flow__label,
        .order-flow[data-step="4"] .order-flow__step[data-flow-step="1"] .order-flow__label,
        .order-flow[data-step="4"] .order-flow__step[data-flow-step="2"] .order-flow__label,
        .order-flow[data-step="4"] .order-flow__step[data-flow-step="3"] .order-flow__label {
            color: #666;
        }
        .order-flow__hint {
            margin: 16px 0 0;
            font-size: 12px;
            color: #666;
            text-align: center;
            line-height: 1.45;
            min-height: 1.2em;
        }
        .order-flow--celebrate .order-flow__track {
            animation: order-flow-shine 0.8s ease;
        }
        @keyframes order-flow-pulse {
            0%, 100% { box-shadow: 0 0 0 4px rgba(201, 162, 39, 0.15); }
            50% { box-shadow: 0 0 0 8px rgba(201, 162, 39, 0.28); }
        }
        @keyframes order-flow-pop {
            0% { transform: scale(0.85); }
            60% { transform: scale(1.12); }
            100% { transform: scale(1.06); }
        }
        @keyframes order-flow-shine {
            0% { opacity: 0.6; }
            100% { opacity: 1; }
        }
        @media (max-width: 480px) {
            .order-flow { padding: 18px 12px 16px; margin: 22px 0 26px; }
            .order-flow__dot { width: 36px; height: 36px; }
            .order-flow__dot-inner { font-size: 11px; }
            .order-flow__label { font-size: 9px; }
            .order-flow__line { left: 10%; right: 10%; top: 18px; }
        }
        .order-flow--compact {
            margin: 0;
            padding: 14px 12px 12px;
            max-width: none;
            border-radius: 0;
            border: none;
            border-bottom: 1px solid #eee;
            background: #faf8f5;
        }
        .order-flow__title--compact {
            margin-bottom: 12px;
            font-size: 10px;
        }
        .order-flow--compact .order-flow__dot { width: 32px; height: 32px; }
        .order-flow--compact .order-flow__dot-inner { font-size: 10px; }
        .order-flow--compact .order-flow__label { font-size: 8px; }
        .order-flow--compact .order-flow__line { top: 16px; }
        .order-flow--compact .order-flow__hint { margin-top: 10px; font-size: 11px; }

        /* Bottom timeline bar (visible when adding to cart) */
        .order-flow-bottom-bar {
            position: fixed;
            left: 0;
            right: 0;
            bottom: 0;
            z-index: 960;
            padding: 0 12px calc(12px + env(safe-area-inset-bottom, 0px));
            pointer-events: none;
            opacity: 0;
            visibility: hidden;
            transform: translateY(110%);
            transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.35s ease, visibility 0.35s ease;
        }
        .order-flow-bottom-bar.is-visible {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }
        .order-flow-bottom-bar .order-flow {
            margin: 0;
            max-width: 560px;
            margin-left: auto;
            margin-right: auto;
            box-shadow: 0 -12px 40px rgba(0, 0, 0, 0.12);
            pointer-events: auto;
        }
        body:has(.sticky-mobile-atc) .order-flow-bottom-bar.is-visible {
            padding-bottom: calc(76px + env(safe-area-inset-bottom, 0px));
        }
        body:has(.global-cart-drawer.active) .order-flow-bottom-bar {
            opacity: 0;
            visibility: hidden;
            transform: translateY(110%);
        }

        /* ===== GLOBAL CART DRAWER ===== */
        :root {
            --cart-primary: #121212;
            --cart-secondary: #c9a227;
            --cart-border: #e0e0e0;
            --cart-white: #ffffff;
        }

        .global-cart-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.5); z-index: 9998; display: none; opacity: 0;
            transition: opacity 0.3s;
        }
        .global-cart-overlay.active { display: block; opacity: 1; }

        .global-cart-drawer {
            position: fixed; top: 0; right: -450px; width: 420px; max-width: 95vw; height: 100%;
            background: var(--cart-white); z-index: 9999;
            box-shadow: -10px 0 40px rgba(0,0,0,0.15);
            display: flex; flex-direction: column;
            transition: right 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            font-family: 'Inter', sans-serif;
        }
        .global-cart-drawer.active { right: 0; }

        .gcd-header {
            display: flex; justify-content: space-between; align-items: center;
            padding: 25px 30px; border-bottom: 1px solid var(--cart-border);
        }
        .gcd-header h3 {
            font-family: 'Playfair Display', serif; font-size: 22px;
            color: var(--cart-primary); margin: 0;
        }
        .gcd-close {
            font-size: 28px; cursor: pointer; color: var(--cart-primary);
            line-height: 1; background: none; border: none; padding: 4px;
        }

        .gcd-items { flex: 1; overflow-y: auto; padding: 20px 30px; }
        .gcd-empty { text-align: center; padding: 60px 0; color: #999; font-size: 15px; line-height: 2; }
        .gcd-empty a { color: var(--cart-primary); text-decoration: underline; }

        .gcd-item { display: flex; gap: 16px; padding: 18px 0; border-bottom: 1px solid #f0f0f0; align-items: center; }
        .gcd-item-img { width: 80px; height: 80px; border-radius: 8px; overflow: hidden; flex-shrink: 0; }
        .gcd-item-img img { width: 100%; height: 100%; object-fit: cover; }
        .gcd-item-info { flex: 1; }
        .gcd-item-title { font-weight: 600; font-size: 15px; color: var(--cart-primary); margin-bottom: 4px; }
        .gcd-item-price { font-size: 14px; color: #666; margin-bottom: 10px; }
        .gcd-item-qty { display: flex; align-items: center; gap: 10px; }
        .gcd-qty-btn {
            width: 30px; height: 30px; border: 1px solid var(--cart-border);
            border-radius: 50%; background: none; cursor: pointer; font-size: 16px;
            display: flex; align-items: center; justify-content: center; color: var(--cart-primary);
            transition: background 0.2s;
        }
        .gcd-qty-btn:hover { background: #f5f5f5; }
        .gcd-qty-num { font-weight: 600; font-size: 14px; min-width: 24px; text-align: center; }
        .gcd-item-remove {
            color: #ccc; cursor: pointer; font-size: 22px;
            background: none; border: none; padding: 4px; line-height: 1;
            transition: color 0.2s;
        }
        .gcd-item-remove:hover { color: #e74c3c; }

        .gcd-item--gift {
            background: #faf8f5;
            margin: 0 -8px;
            padding: 18px 8px;
            border-radius: 10px;
            border-bottom: 1px solid #ece8e2 !important;
        }
        .gcd-gift-badge {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--cart-secondary);
            display: block;
            margin-bottom: 6px;
        }
        .gcd-price-free { color: #1b5e20; font-weight: 700; }

        .gcd-footer { padding: 20px 30px; border-top: 1px solid var(--cart-border); }
        .gcd-subtotal {
            display: flex; justify-content: space-between;
            font-size: 16px; margin-bottom: 20px; align-items: center;
        }
        .gcd-subtotal-label { color: #666; }
        .gcd-subtotal-value { font-weight: 700; color: var(--cart-primary); font-size: 20px; }
        .gcd-checkout-btn {
            display: block; width: 100%; background: var(--cart-primary); color: white;
            padding: 18px; border: none; border-radius: 40px; font-size: 15px; font-weight: 700;
            text-transform: uppercase; letter-spacing: 1.5px; cursor: pointer;
            text-align: center; text-decoration: none; transition: background 0.2s;
            font-family: 'Inter', sans-serif;
        }
        .gcd-checkout-btn:hover { background: #333; }
        .gcd-view-cart {
            display: block; text-align: center; margin-top: 14px;
            color: #999; font-size: 13px; text-decoration: underline;
            cursor: pointer; background: none; border: none; width: 100%;
            font-family: 'Inter', sans-serif;
        }

        /* Cart count badge - global */
        .g-cart-count {
            background: var(--cart-secondary); color: white;
            border-radius: 50%; width: 18px; height: 18px;
            font-size: 11px; font-weight: 700;
            display: inline-flex; align-items: center; justify-content: center;
            vertical-align: super; margin-left: 2px; line-height: 1;
        }

        /* Toast — hidden until gShowToast() after successful add */
        .g-atc-toast {
            position: fixed; bottom: 30px; left: 50%;
            transform: translateX(-50%) translateY(12px);
            background: var(--cart-primary); color: white;
            padding: 14px 28px; border-radius: 40px;
            font-weight: 600; font-size: 14px; z-index: 99999;
            transition: transform 0.4s ease, opacity 0.35s ease, visibility 0.35s ease;
            white-space: nowrap; box-shadow: 0 4px 20px rgba(0,0,0,0.3);
            font-family: 'Inter', sans-serif;
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
        }
        .g-atc-toast.show {
            transform: translateX(-50%) translateY(0);
            opacity: 1;
            visibility: visible;
            pointer-events: auto;
        }

        /* ===== GLOBAL SEARCH OVERLAY ===== */
        .search-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(255,255,255,0.98); z-index: 10000;
            display: none; align-items: center; justify-content: center;
            opacity: 0; transition: opacity 0.4s ease;
            backdrop-filter: blur(10px);
        }
        .search-overlay.active { display: flex; opacity: 1; }
        
        .search-container { width: 90%; max-width: 800px; text-align: center; transform: translateY(30px); transition: transform 0.5s ease; }
        .search-overlay.active .search-container { transform: translateY(0); }

        .search-header { position: absolute; top: 40px; right: 5%; }
        .search-close { background: none; border: none; font-size: 40px; cursor: pointer; color: var(--cart-primary); }

        .search-form { position: relative; width: 100%; }
        .search-input {
            width: 100%; background: none; border: none; border-bottom: 2px solid var(--cart-primary);
            padding: 20px 0; font-size: clamp(24px, 5vw, 48px); font-family: 'Playfair Display', serif;
            color: var(--cart-primary); outline: none; text-align: center;
        }
        .search-input::placeholder { color: #ccc; }
        
        .search-hint { margin-top: 20px; font-size: 14px; color: #999; text-transform: uppercase; letter-spacing: 2px; }
        
        .trending-searches { margin-top: 50px; display: flex; flex-wrap: wrap; gap: 15px; justify-content: center; }
        .trending-tag { 
            padding: 8px 20px; border: 1px solid #eee; border-radius: 40px; 
            text-decoration: none; color: #666; font-size: 13px; transition: all 0.3s;
        }
        .trending-tag:hover { background: var(--cart-primary); color: white; border-color: var(--cart-primary); }
    </style>
</head>
<body>

{{ content_for_layout }}

<!-- ===== GLOBAL CART DRAWER ===== -->
<div class="global-cart-overlay" id="gCartOverlay" onclick="gCloseCart()"></div>
<div class="global-cart-drawer" id="gCartDrawer">
    <div class="gcd-header">
        <h3>Your Cart</h3>
        <button class="gcd-close" onclick="gCloseCart()">&times;</button>
    </div>
    <div class="gcd-order-flow" id="gcdOrderFlow" hidden>
        {% render 'order-flow-animated', flow_step: 2, compact: true %}
    </div>
    <div class="gcd-items" id="gcdItems">
        <div class="gcd-empty">🛒 Your cart is empty.<br><a href="/collections/all">Start Shopping</a></div>
    </div>
    <div class="gcd-footer" id="gcdFooter" style="display:none;">
        <div class="gcd-subtotal">
            <span class="gcd-subtotal-label">Subtotal</span>
            <span class="gcd-subtotal-value" id="gcdTotal">Rs. 0.00</span>
        </div>
        <a href="/checkout" class="gcd-checkout-btn">Checkout</a>
        <button class="gcd-view-cart" onclick="window.location='/cart'">View Full Cart</button>
    </div>
</div>

<div class="order-flow-bottom-bar" id="orderFlowBottomBar" hidden aria-live="polite">
    {% render 'order-flow-animated', flow_step: 2, compact: true %}
</div>

<div class="g-atc-toast" id="gAtcToast">&#10003; Added to Cart!</div>

<!-- ===== GLOBAL SEARCH OVERLAY ===== -->
<div class="search-overlay" id="gSearchOverlay">
    <div class="search-header">
        <button class="search-close" onclick="gCloseSearch()">&times;</button>
    </div>
    <div class="search-container">
        <form action="/search" method="get" class="search-form">
            <input type="text" name="q" class="search-input" id="gSearchInput" placeholder="What are you looking for?" autocomplete="off">
            <div class="search-hint">Press Enter to search</div>
        </form>
        <div class="trending-searches">
            <a href="/search?q=shampoo" class="trending-tag">Shampoo</a>
            <a href="/search?q=hair" class="trending-tag">Hair Care</a>
            <a href="/search?q=scalp" class="trending-tag">Scalp care</a>
        </div>
    </div>
</div>

<script>
    function gOpenCart() {
        document.getElementById('gCartDrawer').classList.add('active');
        document.getElementById('gCartOverlay').classList.add('active');
        document.body.style.overflow = 'hidden';
        gFetchCart();
    }
    function gCloseCart() {
        document.getElementById('gCartDrawer').classList.remove('active');
        document.getElementById('gCartOverlay').classList.remove('active');
        document.body.style.overflow = '';
        gHideOrderFlowBar();
    }
    function gShowToast() {
        const t = document.getElementById('gAtcToast');
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 3000);
    }
    function gUpdateCount(n) {
        document.querySelectorAll('.g-cart-count').forEach(el => el.textContent = n);
    }
    function gFormatMoney(cents) {
        return 'Rs. ' + (cents / 100).toLocaleString();
    }
    async function gFetchCart() {
        const r = await fetch('/cart.js');
        const cart = await r.json();
        gRenderCart(cart);
    }
    function gIsGiftLine(item) {
        const p = item.properties;
        if (!p) return false;
        if (p['Free gift'] != null || p['_gift'] != null) return true;
        if (Array.isArray(p)) {
            return p.some((prop) => {
                const name = prop && prop.name;
                const val = String((prop && prop.value) || '');
                return name === 'Free gift' || name === '_gift' || val.indexOf('BOGO') >= 0;
            });
        }
        return Object.keys(p).some((k) => {
            if (k === 'Free gift' || k === '_gift') return true;
            return String(p[k] || '').indexOf('BOGO') >= 0;
        });
    }
    const G_BOGO_MAIN = 'scalp-cleanse';
    const G_BOGO_GIFT = 'conditioning-creme';
    function gIsBogoMainLine(item) {
        return item && item.handle === G_BOGO_MAIN && !gIsGiftLine(item);
    }
    function gIsBogoGiftLine(item) {
        return item && item.handle === G_BOGO_GIFT && gIsGiftLine(item);
    }
    function gLinePriceDisplay(item) {
        const final = item.final_line_price != null ? item.final_line_price : (item.line_price != null ? item.line_price : (item.price * item.quantity));
        const gift = gIsGiftLine(item);
        if (gift && final === 0) return '<span class="gcd-price-free">FREE</span>';
        return gFormatMoney(final);
    }
    function gRenderCart(cart) {
        const items = document.getElementById('gcdItems');
        const footer = document.getElementById('gcdFooter');
        const total = document.getElementById('gcdTotal');
        gUpdateCount(cart.item_count);
        if (!cart.item_count) {
            items.innerHTML = '<div class="gcd-empty">🛒 Your cart is empty.<br><a href="/collections/all">Start Shopping</a></div>';
            footer.style.display = 'none';
            gToggleCartOrderFlow(false);
            return;
        }
        footer.style.display = 'block';
        let flowStep = 2;
        try {
            const saved = parseInt(sessionStorage.getItem('avyen_order_flow_step') || '2', 10);
            if (saved >= 2 && saved <= 4) flowStep = saved;
        } catch (e) {}
        gToggleCartOrderFlow(true, flowStep);
        total.textContent = gFormatMoney(cart.total_price);
        items.innerHTML = cart.items.map((item, idx) => {
            const gift = gIsGiftLine(item);
            const title = (item.product_title || '') + (item.variant_title && item.variant_title !== 'Default Title' ? ' — ' + item.variant_title : '');
            const qtyControls = gift
                ? `<div class="gcd-item-qty"><span class="gcd-qty-num">${item.quantity}</span><span style="font-size:12px;color:#888;margin-left:8px;">Free gift</span></div>`
                : `<div class="gcd-item-qty">
                        <button type="button" class="gcd-qty-btn" onclick="gChangeQty(${idx + 1}, ${item.quantity - 1})">−</button>
                        <span class="gcd-qty-num">${item.quantity}</span>
                        <button type="button" class="gcd-qty-btn" onclick="gChangeQty(${idx + 1}, ${item.quantity + 1})">+</button>
                   </div>`;
            return `
            <div class="gcd-item${gift ? ' gcd-item--gift' : ''}">
                <div class="gcd-item-img"><img src="${item.image}" alt="${(item.product_title || '').replace(/"/g, '')}"></div>
                <div class="gcd-item-info">
                    ${gift ? '<span class="gcd-gift-badge">Free Gift</span>' : ''}
                    <div class="gcd-item-title">${title}</div>
                    <div class="gcd-item-price">${gLinePriceDisplay(item)}</div>
                    ${qtyControls}
                </div>
                <button type="button" class="gcd-item-remove" onclick="gChangeQty(${idx + 1}, 0)" aria-label="Remove">×</button>
            </div>`;
        }).join('');
    }
    /** BOGO: gift Conditioning Creme qty matches Scalp Cleanse; no scalp = remove all free gifts */
    async function gRemoveBogoGiftLine(line) {
        return fetch('/cart/change.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ line, quantity: 0 })
        });
    }
    async function gRemoveAllBogoMainLines() {
        for (let n = 0; n < 10; n++) {
            const cart = await fetch('/cart.js').then((r) => r.json());
            const mi = cart.items.findIndex((item) => gIsBogoMainLine(item));
            if (mi < 0) break;
            const res = await fetch('/cart/change.js', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ line: mi + 1, quantity: 0 })
            });
            if (!res.ok) break;
        }
    }
    async function gSyncBogoGiftQuantities() {
        let cart = await fetch('/cart.js').then((r) => r.json());
        for (let iter = 0; iter < 20; iter++) {
            let mainTotal = 0;
            const gifts = [];
            cart.items.forEach((item, i) => {
                const line = i + 1;
                if (gIsBogoMainLine(item)) mainTotal += item.quantity;
                if (gIsBogoGiftLine(item)) gifts.push({ line, qty: item.quantity });
            });
            if (mainTotal === 0 && gifts.length > 0) {
                const last = gifts[gifts.length - 1];
                const res = await gRemoveBogoGiftLine(last.line);
                if (!res.ok) break;
                cart = await fetch('/cart.js').then((r) => r.json());
                continue;
            }
            const giftTotal = gifts.reduce((s, g) => s + g.qty, 0);
            if (!gifts.length || giftTotal === mainTotal) break;
            let res;
            if (giftTotal > mainTotal) {
                const last = gifts[gifts.length - 1];
                const dec = Math.min(last.qty, giftTotal - mainTotal);
                res = await fetch('/cart/change.js', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ line: last.line, quantity: last.qty - dec })
                });
            } else {
                const first = gifts[0];
                const inc = mainTotal - giftTotal;
                res = await fetch('/cart/change.js', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ line: first.line, quantity: first.qty + inc })
                });
            }
            if (!res.ok) break;
            cart = await fetch('/cart.js').then((r) => r.json());
        }
    }
    async function gChangeQty(line, qty) {
        qty = Math.max(0, qty);
        const cartBefore = await fetch('/cart.js').then((r) => r.json());
        const changed = cartBefore.items[line - 1];
        if (qty === 0 && changed && gIsBogoGiftLine(changed)) {
            await gRemoveAllBogoMainLines();
            for (let n = 0; n < 10; n++) {
                const cart = await fetch('/cart.js').then((r) => r.json());
                const gi = cart.items.findIndex((item) => gIsBogoGiftLine(item));
                if (gi < 0) break;
                await gRemoveBogoGiftLine(gi + 1);
            }
            await gSyncBogoGiftQuantities();
            gFetchCart();
            return;
        }
        const res = await fetch('/cart/change.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ line: line, quantity: qty })
        });
        if (!res.ok) {
            gFetchCart();
            return;
        }
        if (qty === 0 && changed && gIsBogoMainLine(changed)) {
            for (let n = 0; n < 10; n++) {
                const cart = await fetch('/cart.js').then((r) => r.json());
                const gi = cart.items.findIndex((item) => gIsBogoGiftLine(item));
                if (gi < 0) break;
                await gRemoveBogoGiftLine(gi + 1);
            }
        }
        await gSyncBogoGiftQuantities();
        gFetchCart();
    }
    async function gAddToCart(id, btn, qty = 1) {
        const orig = btn && (btn.dataset.atcLabel || (btn.dataset.atcLabel = btn.textContent.trim()));
        if (btn) { btn.textContent = 'ADDING...'; btn.disabled = true; }
        try {
            const res = await fetch('/cart/add.js', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: Number(id), quantity: qty })
            });
            if (!res.ok) throw new Error(await res.text());
            if (btn) { btn.textContent = '✓ ADDED!'; setTimeout(() => { btn.textContent = orig; btn.disabled = false; }, 2000); }
            gAfterAddToCartSuccess();
        } catch (e) {
            alert('Could not add to cart. Please try again.');
            if (btn) { btn.textContent = orig; btn.disabled = false; }
        }
    }
    /** Adds Scalp Cleanse + Conditioning Creme (mark gift line). Set a Shopify automatic discount so the gift line prices at Rs. 0 at checkout. */
    async function gAddToCartWithGift(mainVariantId, giftVariantId, btn, qty = 1) {
        const orig = btn && (btn.dataset.atcLabel || (btn.dataset.atcLabel = btn.textContent.trim()));
        if (btn) { btn.textContent = 'ADDING...'; btn.disabled = true; }
        try {
            const res = await fetch('/cart/add.js', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    items: [
                        { id: Number(mainVariantId), quantity: qty },
                        {
                            id: Number(giftVariantId),
                            quantity: qty,
                            properties: { 'Free gift': 'BOGO — Avyen Conditioning Creme (worth Rs. 2,090)' }
                        }
                    ]
                })
            });
            if (!res.ok) throw new Error(await res.text());
            if (btn) { btn.textContent = '✓ ADDED!'; setTimeout(() => { btn.textContent = orig; btn.disabled = false; }, 2000); }
            gAfterAddToCartSuccess();
        } catch (e) {
            alert('Could not add to cart. Please try again.');
            if (btn) { btn.textContent = orig; btn.disabled = false; }
        }
    }
    function gShowOrderFlowBar() {
        const bar = document.getElementById('orderFlowBottomBar');
        if (!bar) return;
        bar.hidden = false;
        requestAnimationFrame(() => bar.classList.add('is-visible'));
    }
    function gHideOrderFlowBar() {
        const bar = document.getElementById('orderFlowBottomBar');
        if (!bar) return;
        bar.classList.remove('is-visible');
        setTimeout(() => {
            if (!bar.classList.contains('is-visible')) bar.hidden = true;
        }, 450);
    }
    function gToggleCartOrderFlow(show, step) {
        const wrap = document.getElementById('gcdOrderFlow');
        if (!wrap) return;
        wrap.hidden = !show;
        if (show && step) gSetOrderFlowStep(step);
    }
    function gAfterAddToCartSuccess() {
        gSetOrderFlowStep(2);
        gShowOrderFlowBar();
        gShowToast();
        setTimeout(() => {
            gHideOrderFlowBar();
            gToggleCartOrderFlow(true, 2);
            gOpenCart();
        }, 1100);
    }
    const gOrderFlowHints = {
        1: 'Tap Add to Cart to start your order.',
        2: 'Great — review your cart and continue when ready.',
        3: 'Complete checkout to confirm your order.',
        4: 'Thank you! Your order has been placed successfully.'
    };
    function gSetOrderFlowStep(step) {
        step = Math.max(1, Math.min(4, parseInt(step, 10) || 1));
        document.querySelectorAll('[data-order-flow]').forEach((el) => {
            el.setAttribute('data-step', String(step));
            el.classList.toggle('order-flow--celebrate', step === 4);
            const hint = el.querySelector('[data-flow-hint]');
            if (hint) hint.textContent = gOrderFlowHints[step] || '';
        });
        try { sessionStorage.setItem('avyen_order_flow_step', String(step)); } catch (e) {}
    }
    function gInitOrderFlow() {
        const params = new URLSearchParams(window.location.search);
        if (params.get('order_placed') === '1') {
            gSetOrderFlowStep(4);
            try { sessionStorage.removeItem('avyen_checkout_started'); } catch (e) {}
            return;
        }
        document.querySelectorAll('[data-order-flow]').forEach((el) => {
            const step = parseInt(el.getAttribute('data-step') || '1', 10);
            gSetOrderFlowStep(step);
        });
    }
    function gBindOrderFlowCheckout() {
        document.querySelectorAll('button[name="checkout"], .gcd-checkout-btn').forEach((btn) => {
            if (btn.dataset.flowBound) return;
            btn.dataset.flowBound = '1';
            btn.addEventListener('click', () => {
                gSetOrderFlowStep(3);
                try { sessionStorage.setItem('avyen_checkout_started', String(Date.now())); } catch (e) {}
            });
        });
    }
    function gOpenSearch() {
        document.getElementById('gSearchOverlay').classList.add('active');
        document.body.style.overflow = 'hidden';
        setTimeout(() => document.getElementById('gSearchInput').focus(), 400);
    }
    function gCloseSearch() {
        document.getElementById('gSearchOverlay').classList.remove('active');
        document.body.style.overflow = '';
    }
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { gCloseSearch(); gCloseCart(); } });
    document.addEventListener('DOMContentLoaded', () => {
        gInitOrderFlow();
        gBindOrderFlowCheckout();
    });
</script>
</body>
</html>
